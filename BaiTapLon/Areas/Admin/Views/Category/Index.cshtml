@model X.PagedList.IPagedList<Mood.EF2.Category>
@using X.PagedList.Mvc;
@{
    ViewBag.Title = "Danh sách thể loại";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}
<!-- Breadcrumbs-->
<ol class="breadcrumb bg-card border border-color rounded-md py-2 px-3 shadow-sm mb-4">
    <li class="breadcrumb-item">
        <a href="/Admin/Homes" class="text-primary font-weight-semibold">Trang Chủ</a>
    </li>
    <li class="breadcrumb-item active text-muted">Quản lý thể loại</li>
</ol>

<div class="card bg-card border-color shadow-sm rounded-lg mb-4">
    <div class="card-body p-3">
        @using (Html.BeginForm("Index", "Category", FormMethod.Get, new { @class = "m-0" }))
        {
            <div class="row align-items-center">
                <div class="col-md-8 col-sm-12 mb-2 mb-md-0">
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-app border-color text-muted">
                                <i class="fas fa-search"></i>
                            </span>
                        </div>
                        <input class="form-control bg-app border-color text-main rounded-right-md" type="text" name="searhString" placeholder="Nhập từ khóa cần tìm kiếm..." />
                    </div>
                </div>
                <div class="col-md-4 col-sm-12 text-md-right">
                    <button type="submit" class="btn btn-primary px-4 rounded-md mr-2">
                        <i class="fas fa-search mr-1"></i> Tìm kiếm
                    </button>
                    <a href="/Admin/Category/Create" class="btn btn-success rounded-md">
                        <i class="fas fa-plus mr-1"></i> Thêm thể loại mới
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<div class="card bg-card border-color shadow-sm rounded-lg overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover table-striped border-0 mb-0">
            <thead>
                <tr class="bg-app text-muted font-size-2 border-bottom border-color text-uppercase font-weight-bold">
                    <th class="px-4 py-3 border-0">Tên thể loại</th>
                    <th class="px-4 py-3 border-0">Thẻ SEO</th>
                    <th class="px-4 py-3 border-0">Người Tạo</th>
                    <th class="px-4 py-3 border-0 text-center">Trạng thái</th>
                    <th class="px-4 py-3 border-0 text-center">Hành động</th>
                </tr>
            </thead>
            <tbody class="text-main font-size-2 align-middle">
                @foreach (var item in Model)
                {
                    <tr id="row_@item.IDCategory" class="border-bottom border-color">
                        <td class="px-4 py-3 border-0 font-weight-semibold">@item.TenTheloai</td>
                        <td class="px-4 py-3 border-0 text-muted">@item.MetaTitle</td>
                        <td class="px-4 py-3 border-0">@item.NguoiTao</td>
                        <td class="px-4 py-3 border-0 text-center">
                            @if (item.Status)
                            {
                                <span class="badge bg-success-light text-success px-2.5 py-1 rounded-full font-weight-bold">
                                    <i class="fas fa-check-circle mr-1"></i> Hoạt Động
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger-light text-danger px-2.5 py-1 rounded-full font-weight-bold">
                                    <i class="fas fa-times-circle mr-1"></i> Đã Khóa
                                </span>
                            }
                        </td>
                        <td class="px-4 py-3 border-0 text-center">
                            <div class="d-inline-flex" style="gap: 5px;">
                                <a href="/Admin/Category/Edit/@item.IDCategory" class="btn btn-sm btn-outline-info rounded-md" title="Chỉnh sửa"><i class="fas fa-user-edit"></i> Sửa</a>
                                @Ajax.ActionLink(" Xóa", "Delete", new { @id = item.IDCategory }, new AjaxOptions
                                {
                                    Confirm = "Bạn có muốn xóa thể loại này?",
                                    OnComplete = "$('#row_" + item.IDCategory + "').remove()",
                                    HttpMethod = "Delete"
                                }, new { @class = "btn btn-sm btn-outline-danger rounded-md far fa-trash-alt" })
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="d-flex justify-content-center mt-4">
    @Html.PagedListPager(Model, page => Url.Action("Index", new { page = page }),
        new PagedListRenderOptions
        {
            LiElementClasses = new string[] { "page-item" },
            LinkToPreviousPageFormat = "<i class='fas fa-chevron-left'></i> Trước",
            LinkToNextPageFormat = "Kế Tiếp <i class='fas fa-chevron-right'></i>",
            PageClasses = new string[] { "page-link bg-card border-color text-main rounded-md mx-1 font-size-2" }
        })
</div>
