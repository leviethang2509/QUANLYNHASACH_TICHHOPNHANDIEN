@model X.PagedList.IPagedList<Mood.EF2.Orders>
@using X.PagedList.Mvc;
@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

@section jsFooter{
    <link href="~/Content/libs/toastr/toastr.css" rel="stylesheet" />
    <script src="~/Content/libs/commonjs/dongGoiController.js"></script>
}

<!-- Breadcrumbs-->
<ol class="breadcrumb bg-card border border-color rounded-md py-2 px-3 shadow-sm mb-4">
    <li class="breadcrumb-item">
        <a href="/Admin/Homes" class="text-primary font-weight-semibold">Trang Chủ</a>
    </li>
    <li class="breadcrumb-item active text-muted">Quản lý hóa đơn</li>
</ol>

<div class="card bg-card border-color shadow-sm rounded-lg mb-4">
    <div class="card-body p-3">
        @using (Html.BeginForm("XacNhan", "HoaDon", FormMethod.Get, new { @class = "m-0" }))
        {
            <div class="row align-items-center">
                <div class="col-md-9 col-sm-12 mb-2 mb-md-0">
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-app border-color text-muted">
                                <i class="fas fa-search"></i>
                            </span>
                        </div>
                        <input class="form-control bg-app border-color text-main rounded-right-md" type="text" name="searhString" placeholder="Nhập từ khóa cần tìm kiếm..." />
                    </div>
                </div>
                <div class="col-md-3 col-sm-12 text-md-right">
                    <button type="submit" class="btn btn-primary btn-block px-4 rounded-md">
                        <i class="fas fa-search mr-1"></i> Tìm kiếm
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<div class="card bg-card border-color shadow-sm rounded-lg mb-4 p-4">
    <ul class="bs4-order-tracking mb-4">
        <li class="step active">
            <div><i class="fas fa-user"></i></div> <a href="/Admin/HoaDon/XacNhan" class="text-main font-weight-bold">Duyệt Đơn</a>
        </li>
        <li class="step">
            <div><i class="fas fa-bread-slice"></i></div><a href="/Admin/HoaDon/DongGoi" class="text-muted">Đóng Gói</a>
        </li>
        <li class="step">
            <div><i class="fas fa-truck"></i></div> <a href="/Admin/HoaDon/XuatKho" class="text-muted">Xuất Kho</a>
        </li>
        <li class="step">
            <div><i class="fas fa-birthday-cake"></i></div> <a href="/Admin/HoaDon/HoanThanh" class="text-muted">Hoàn Thành</a>
        </li>
    </ul>
    
    <div class="alert bg-app border-color text-center py-2 px-3 rounded-md mb-0">
        <p class="text-main mb-1"><b>Chú Ý:</b> Xác nhận thông tin của khách hàng trước khi <span class="badge bg-info-light text-info">Duyệt Đơn</span>.</p>
        <p class="text-muted mb-0"><b>Hướng Dẫn:</b> Bạn click vào <span class="badge bg-info-light text-info">Duyệt Đơn</span> để duyệt đơn hàng nhanh nhất.</p>
    </div>
</div>

<div class="card bg-card border-color shadow-sm rounded-lg overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover table-striped border-0 mb-0">
            <thead>
                <tr class="bg-app text-muted font-size-2 border-bottom border-color text-uppercase font-weight-bold text-center">
                    <th class="px-3 py-3 border-0">Mã HĐ</th>
                    <th class="px-3 py-3 border-0">Tên Khách Hàng</th>
                    <th class="px-3 py-3 border-0">Địa Chỉ Nhận</th>
                    <th class="px-3 py-3 border-0">Email</th>
                    <th class="px-3 py-3 border-0">Số Điện Thoại</th>
                    <th class="px-3 py-3 border-0">Ngày Tạo</th>
                    <th class="px-3 py-3 border-0">Phương Thức</th>
                    <th class="px-3 py-3 border-0">Thanh Toán</th>
                    <th class="px-3 py-3 border-0">Trạng Thái</th>
                    <th class="px-3 py-3 border-0">Xem Chi Tiết</th>
                    <th class="px-3 py-3 border-0">Hành động</th>
                </tr>
            </thead>
            <tbody class="text-main font-size-2 align-middle text-center">
                @foreach (var item in Model)
                {
                    <tr id="row_@item.IDOder" class="border-bottom border-color">
                        <td class="px-3 py-3 border-0 font-weight-semibold">@item.IDOder</td>
                        <td class="px-3 py-3 border-0 font-weight-semibold">@item.ShipName</td>
                        <td class="px-3 py-3 border-0 text-muted">@item.ShipAddress</td>
                        <td class="px-3 py-3 border-0">@item.ShipEmail</td>
                        <td class="px-3 py-3 border-0">@item.ShipMobile</td>
                        <td class="px-3 py-3 border-0">@item.NgayTao</td>
                        <td class="px-3 py-3 border-0">
                            @if (item.DeliveryPaymentMethod.Equals("COD"))
                            {
                                <span class="badge bg-app text-primary border border-primary px-2 py-1 rounded">COD</span>
                            }
                            else if (item.DeliveryPaymentMethod.Equals("ATM"))
                            {
                                <span class="badge bg-app text-success border border-success px-2 py-1 rounded">ATM</span>
                            }
                            else if (item.DeliveryPaymentMethod.Equals("Ngân Lượng"))
                            {
                                <span class="badge bg-app text-info border border-info px-2 py-1 rounded">Ngân lượng</span>
                            }
                            else
                            {
                                <span class="badge bg-app text-danger border border-danger px-2 py-1 rounded">MOMO</span>
                            }
                        </td>
                        <td class="px-3 py-3 border-0">
                            @if (item.StatusPayment == 2)
                            {
                                <span class="badge bg-warning-light text-warning px-2.5 py-1 rounded-full font-weight-bold">Chưa Thanh Toán</span>
                            }
                            else
                            {
                                <span class="badge bg-success-light text-success px-2.5 py-1 rounded-full font-weight-bold">Đã Thanh Toán</span>
                            }
                        </td>
                        <td class="px-3 py-3 border-0">
                            @if (item.Status == 0)
                            {
                                <a href="#" class="btn-active-Status badge bg-info-light text-info px-2.5 py-1 rounded-full border-0 font-weight-bold" data-id="@item.IDOder">
                                    <i class="fas fa-spinner mr-1"></i> Duyệt Đơn
                                </a>
                            }
                            else
                            {
                                <a href="#" class="btn-active-Status badge bg-success-light text-success px-2.5 py-1 rounded-full border-0 font-weight-bold" data-id="@item.IDOder">
                                    <i class="fas fa-check mr-1"></i> Đã Duyệt
                                </a>
                            }
                        </td>
                        <td class="px-3 py-3 border-0">
                            <a href="/Admin/HoaDon/Details/@item.IDOder" class="btn btn-sm btn-outline-info rounded-md">
                                <i class="fas fa-info-circle mr-1"></i> Chi Tiết
                            </a>
                        </td>
                        <td class="px-3 py-3 border-0">
                            <div class="d-inline-flex" style="gap: 5px;">
                                <a href="#" class="buttonExport btn btn-sm btn-outline-success rounded-md" data-id="@item.IDOder">
                                    <i class="fas fa-file-export mr-1"></i> Export
                                </a>
                                @Ajax.ActionLink(" Xóa", "Delete", new { @id = item.IDOder }, new AjaxOptions
                                {
                                    Confirm = "Bạn có muốn xóa hóa đơn này?",
                                    OnComplete = "$('#row_" + item.IDOder + "').remove()",
                                    HttpMethod = "Delete"
                                }, new { @class = "btn btn-sm btn-outline-danger rounded-md far fa-trash-alt" })
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="d-flex justify-content-center mt-4">
    @Html.PagedListPager(Model, page => Url.Action("XacNhan", new { page = page }),
        new PagedListRenderOptions
        {
            LiElementClasses = new string[] { "page-item" },
            LinkToPreviousPageFormat = "<i class='fas fa-chevron-left'></i> Trước",
            LinkToNextPageFormat = "Kế Tiếp <i class='fas fa-chevron-right'></i>",
            PageClasses = new string[] { "page-link bg-card border-color text-main rounded-md mx-1 font-size-2" }
        })
</div>
