@model X.PagedList.IPagedList<Mood.SanPhamViewModel.SanPhamModel>
@using X.PagedList.Mvc;

@{
    ViewBag.Title = "Quản Lý Sản Phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}
<!-- Breadcrumbs-->
<ol class="breadcrumb bg-card border border-color rounded-md py-2 px-3 shadow-sm mb-4">
    <li class="breadcrumb-item">
        <a href="/Admin/Homes" class="text-primary font-weight-semibold">Trang Chủ</a>
    </li>
    <li class="breadcrumb-item active text-muted">Quản lý sách</li>
</ol>

<div class="card bg-card border-color shadow-sm rounded-lg mb-4">
    <div class="card-body p-3">
        @using (Html.BeginForm("Index", "Sanpham", FormMethod.Get, new { @class = "m-0" }))
        {
            <div class="row align-items-center">
                <div class="col-md-7 col-sm-12 mb-2 mb-md-0">
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-app border-color text-muted">
                                <i class="fas fa-search"></i>
                            </span>
                        </div>
                        <input class="form-control bg-app border-color text-main rounded-right-md" type="text" name="searhString" placeholder="Nhập từ khóa tìm kiếm sách..." />
                    </div>
                </div>
                <div class="col-md-5 col-sm-12 text-md-right">
                    <button type="submit" class="btn btn-primary px-4 rounded-md mr-2">
                        <i class="fas fa-filter mr-1"></i> Lọc
                    </button>
                    <a href="/Admin/Sanpham/Create" class="btn btn-success rounded-md">
                        <i class="fas fa-plus mr-1"></i> Thêm sách mới
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<div class="card bg-card border-color shadow-sm rounded-lg overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover table-striped border-0 mb-0">
            <thead>
                <tr class="bg-app text-muted font-size-2 border-bottom border-color text-uppercase font-weight-bold">
                    <th class="px-3 py-3 border-0">Tên sách</th>
                    <th class="px-3 py-3 border-0">Tác giả</th>
                    <th class="px-3 py-3 border-0">Nhà xuất bản</th>
                    <th class="px-3 py-3 border-0 text-center">Ảnh</th>
                    <th class="px-3 py-3 border-0">Thể loại</th>
                    <th class="px-3 py-3 border-0 text-center">Review</th>
                    <th class="px-3 py-3 border-0 text-center">Video</th>
                    <th class="px-3 py-3 border-0 text-center">Tồn kho</th>
                    <th class="px-3 py-3 border-0 text-center">Trạng thái</th>
                    <th class="px-3 py-3 border-0 text-center">Hành động</th>
                </tr>
            </thead>
            <tbody class="text-main font-size-2 align-middle">
                @foreach (var item in Model)
                {
                    <tr id="row_@item.IDContent" class="border-bottom border-color">
                        <td class="px-3 py-3 border-0 font-weight-semibold" style="max-width: 200px; white-space: normal;">@item.Name</td>
                        <td class="px-3 py-3 border-0 text-muted">@item.TacGia</td>
                        <td class="px-3 py-3 border-0 text-muted">@item.NhaXuatBan</td>
                        <td class="px-3 py-3 border-0 text-center">
                            <img src="@item.Images" alt="Ảnh sách" class="img-thumbnail bg-app border-color rounded-md" style="width: 50px; height: 65px; object-fit: cover;"/>
                        </td>
                        <td class="px-3 py-3 border-0">
                            <span class="badge bg-app text-muted border border-color px-2 py-1 rounded">@item.TenTheloai</span>
                        </td>
                        <td class="px-3 py-3 border-0 text-center">
                            @if (!string.IsNullOrWhiteSpace(item.ReviewFilePath))
                            {
                                <a href="@Url.Action("ReviewFilePreview", "Product", new { area = "", id = item.IDContent })" target="_blank" class="btn btn-outline-primary btn-sm rounded-md"><i class="fas fa-file-pdf"></i> Xem</a>
                            }
                            else
                            {
                                <span class="badge bg-warning-light text-warning px-2 py-1 rounded">Chưa có</span>
                            }
                        </td>
                        <td class="px-3 py-3 border-0 text-center">
                            @if (!string.IsNullOrWhiteSpace(item.YoutubeUrl))
                            {
                                <a href="@item.YoutubeUrl" target="_blank" class="btn btn-outline-danger btn-sm rounded-md"><i class="fab fa-youtube"></i> Xem</a>
                            }
                            else
                            {
                                <span class="badge bg-app text-muted border border-color px-2 py-1 rounded">Chưa có</span>
                            }
                        </td>
                        <td class="px-3 py-3 border-0 text-center font-weight-bold">@item.Soluong</td>
                        <td class="px-3 py-3 border-0 text-center">
                            @if (item.Status)
                            {
                                <span class="badge bg-success-light text-success px-2.5 py-1 rounded-full font-weight-bold">Đang Bán</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-light text-danger px-2.5 py-1 rounded-full font-weight-bold">Ngừng Bán</span>
                            }
                        </td>
                        <td class="px-3 py-3 border-0 text-center">
                            <div class="d-inline-flex" style="gap: 5px;">
                                <a href="/Admin/Sanpham/Edit/@item.IDContent" class="btn btn-sm btn-outline-info rounded-md" title="Sửa"><i class="fas fa-edit"></i> Sửa</a>
                                @Ajax.ActionLink(" Xóa", "Delete", new { @id = item.IDContent }, new AjaxOptions
                                {
                                    Confirm = "Bạn có muốn xóa sách này?",
                                    OnComplete = "$('#row_" + item.IDContent + "').remove()",
                                    HttpMethod = "Delete"
                                }, new { @class = "btn btn-sm btn-outline-danger rounded-md far fa-trash-alt" })
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="d-flex justify-content-center mt-4">
    @Html.PagedListPager(Model, page => Url.Action("Index", new { page = page }),
        new PagedListRenderOptions
        {
            LiElementClasses = new string[] { "page-item" },
            LinkToPreviousPageFormat = "<i class='fas fa-chevron-left'></i> Trước",
            LinkToNextPageFormat = "Kế Tiếp <i class='fas fa-chevron-right'></i>",
            PageClasses = new string[] { "page-link bg-card border-color text-main rounded-md mx-1 font-size-2" }
        })
</div>
