@model Mood.EF2.User
@using BaiTapLon.Common;
@{
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
    var session = (UserLogin)Session[Constant.USER_SESSION];
    var identityFrontImage = Model != null && !string.IsNullOrWhiteSpace(Model.IdentityCardFrontImagePath) ? Model.IdentityCardFrontImagePath : (Model != null ? Model.IdentityCardImagePath : null);
    var identityBackImage = Model != null ? Model.IdentityCardBackImagePath : null;
    var identityProfileLocked = !string.IsNullOrWhiteSpace(identityFrontImage) && !string.IsNullOrWhiteSpace(identityBackImage);
    var identityLockedAttr = identityProfileLocked ? "readonly" : "";
}
@section jsFooter{
    <script src="~/Content/libs/commonjs/userProfileCommon.js?v=20260510-profile-identity-reorder"></script>
}
@if (session != null)
{
    <main id="content">
        <div class="container">
            <div class="row">
                <div class="col-md-3 border-right">
                    <h6 class="font-weight-medium font-size-7 pt-5 pt-lg-8  mb-5 mb-lg-7">Thông tin tài khoản</h6>
                    <div class="tab-wrapper">
                        <ul class="my__account-nav nav flex-column mb-0" role="tablist" id="pills-tab">
                            <li class="nav-item mx-0">
                                <a class="nav-link d-flex align-items-center px-0 active" href="/tong-quan-@session.userId">
                                    <span class="font-weight-normal text-gray-600">Tổng quan</span>
                                </a>
                            </li>
                            <li class="nav-item mx-0">
                                <a class="nav-link d-flex align-items-center px-0" href="/danh-sach-don-hang-@session.userId">
                                    <span class="font-weight-normal text-gray-600">Đơn hàng</span>
                                </a>
                            </li>
                            <li class="nav-item mx-0">
                                <a class="nav-link d-flex align-items-center px-0" href="/tin-nhan-@session.userId">
                                    <span class="font-weight-normal text-gray-600">Thông báo (@session.tolMes)</span>
                                </a>
                            </li>
                            <li class="nav-item mx-0">
                                <a class="nav-link d-flex align-items-center px-0" href="/phan-hoi-@session.userId">
                                    <span class="font-weight-normal text-gray-600">Phản Hồi (@session.tolRep)</span>
                                </a>
                            </li>
                            <li class="nav-item mx-0">
                                <a class="nav-link d-flex align-items-center px-0" href="/thong-tin-ca-nhan-@session.userId">
                                    <span class="font-weight-normal text-gray-600">Thông tin cá nhân</span>
                                </a>
                            </li>
                            <li class="nav-item mx-0">
                                <a class="nav-link d-flex align-items-center px-0" href="/yeu-thich-@session.userId">
                                    <span class="font-weight-normal text-gray-600">Sách yêu thích</span>
                                </a>
                            </li>
                            <li class="nav-item mx-0">
                                <a class="nav-link d-flex align-items-center px-0" href="/Users/Logout">
                                    <span class="font-weight-normal text-gray-600">Thoát</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="col-md-9">
                        <div class="border-bottom mb-6 pb-6 mb-lg-8 pb-lg-9">
                            <div class="pt-5 pl-md-5 pt-lg-8 pl-lg-9">
                                <h6 class="font-weight-medium font-size-7 ml-lg-1 mb-lg-8 pb-xl-1">Thông tin cá nhân</h6>
                                <div class="font-weight-medium font-size-22 mb-4 pb-xl-1">Sửa thông tin</div>
                                @if (identityProfileLocked)
                                {
                                    <div class="alert alert-info rounded-0 mb-4">Tài khoản đã có đủ ảnh CMND/CCCD hai mặt. Các thông tin đã được khóa, bạn chỉ có thể cập nhật lại ảnh CMND/CCCD.</div>
                                }
                                <div class="mb-4">
                                    <form id="IdentityCardUploadForm" class="mt-3" enctype="multipart/form-data">
                                        <div class="border p-4">
                                            <div class="font-weight-medium mb-3">Ảnh CMND/CCCD</div>
                                            <div class="row">
                                                <div class="col-md-6 mb-4">
                                                    <label class="identity-upload-box d-block border text-center p-3" for="profileIdentityFrontFile">
                                                        <span class="d-block font-weight-medium mb-2">Mặt trước</span>
                                                        <img id="profileIdentityFrontPreview" src="@(string.IsNullOrWhiteSpace(identityFrontImage) ? "" : "/" + identityFrontImage)" alt="Ảnh CMND/CCCD mặt trước" class="img-fluid @(string.IsNullOrWhiteSpace(identityFrontImage) ? "d-none" : "")" style="max-height:180px;" />
                                                        <span id="profileIdentityFrontPlaceholder" class="text-gray-600 @(string.IsNullOrWhiteSpace(identityFrontImage) ? "" : "d-none")">Bấm để tải ảnh mặt trước</span>
                                                    </label>
                                                    <input id="profileIdentityFrontFile" type="file" class="d-none js-identity-preview" name="front_file" data-preview="#profileIdentityFrontPreview" data-placeholder="#profileIdentityFrontPlaceholder" accept=".jpg,.jpeg,.png,image/jpeg,image/png" />
                                                </div>
                                                <div class="col-md-6 mb-4">
                                                    <label class="identity-upload-box d-block border text-center p-3" for="profileIdentityBackFile">
                                                        <span class="d-block font-weight-medium mb-2">Mặt sau</span>
                                                        <img id="profileIdentityBackPreview" src="@(string.IsNullOrWhiteSpace(identityBackImage) ? "" : "/" + identityBackImage)" alt="Ảnh CMND/CCCD mặt sau" class="img-fluid @(string.IsNullOrWhiteSpace(identityBackImage) ? "d-none" : "")" style="max-height:180px;" />
                                                        <span id="profileIdentityBackPlaceholder" class="text-gray-600 @(string.IsNullOrWhiteSpace(identityBackImage) ? "" : "d-none")">Bấm để tải ảnh mặt sau</span>
                                                    </label>
                                                    <input id="profileIdentityBackFile" type="file" class="d-none js-identity-preview" name="back_file" data-preview="#profileIdentityBackPreview" data-placeholder="#profileIdentityBackPlaceholder" accept=".jpg,.jpeg,.png,image/jpeg,image/png" />
                                                </div>
                                            </div>
                                            <button id="profileIdentityOcrBtn" type="button" onclick="UploadIdentityCard()" class="btn btn-outline-dark rounded-0">Đọc thông tin</button>
                                            <div id="identityCardUploadStatus" class="font-size-2 mt-3 text-gray-600"></div>
                                        </div>
                                    </form>
                                </div>
                                <form id="ChangeUserProfile" data-identity-locked="@identityProfileLocked.ToString().ToLowerInvariant()">
                                    <div class="row">
                                        <input type="hidden" name="IDUser" value="@Model.IDUser" />
                                        <input type="hidden" name="Name" value="@Model.Name" />
                                        <div class="col-md-12 mb-4">
                                            <div class="border p-4">
                                                <div class="font-weight-medium font-size-3 mb-3">Thông tin CMND/CCCD</div>
                                                <div class="row">
                                                    <div class="col-md-6 mb-4">
                                                        <label>Số CMND/CCCD</label>
                                                        <input type="text" class="form-control rounded-0" name="IdentityNumber" value="@Model.IdentityNumber" @identityLockedAttr>
                                                    </div>
                                                    <div class="col-md-6 mb-4">
                                                        <label>Họ tên trên CMND/CCCD</label>
                                                        <input type="text" class="form-control rounded-0" name="IdentityFullName" value="@Model.IdentityFullName" @identityLockedAttr>
                                                    </div>
                                                    <div class="col-md-6 mb-4">
                                                        <label>Ngày sinh</label>
                                                        <input type="date" class="form-control rounded-0" name="IdentityDateOfBirth" value="@(Model.IdentityDateOfBirth.HasValue ? Model.IdentityDateOfBirth.Value.ToString("yyyy-MM-dd") : "")" @identityLockedAttr>
                                                    </div>
                                                    <div class="col-md-6 mb-4">
                                                        <label>Ngày cấp</label>
                                                        <input type="date" class="form-control rounded-0" name="IdentityIssueDate" value="@(Model.IdentityIssueDate.HasValue ? Model.IdentityIssueDate.Value.ToString("yyyy-MM-dd") : "")" @identityLockedAttr>
                                                    </div>
                                                    <div class="col-md-12 mb-4">
                                                        <label>Địa chỉ trên CMND/CCCD</label>
                                                        <input type="text" class="form-control rounded-0" name="IdentityAddress" value="@Model.IdentityAddress" @identityLockedAttr>
                                                    </div>
                                                    <input type="hidden" name="IdentityPlaceOfBirth" value="@Model.IdentityPlaceOfBirth">
                                                    <input type="hidden" name="IdentityGender" value="@Model.IdentityGender">
                                                    <input type="hidden" name="IdentityNationality" value="@Model.IdentityNationality">
                                                    <input type="hidden" name="IdentityExpiryDate" value="@(Model.IdentityExpiryDate.HasValue ? Model.IdentityExpiryDate.Value.ToString("yyyy-MM-dd") : "")">
                                                    <input type="hidden" name="IdentityIssuingAuthority" value="@Model.IdentityIssuingAuthority">
                                                    <div class="col-md-12 mb-4">
                                                        <label>Nơi cấp</label>
                                                        <input type="text" class="form-control rounded-0" name="IdentityIssuePlace" value="@Model.IdentityIssuePlace" @identityLockedAttr>
                                                    </div>
                                                    @if (!string.IsNullOrWhiteSpace(identityFrontImage) || !string.IsNullOrWhiteSpace(identityBackImage))
                                                    {
                                                        <div class="col-md-12 mb-4">
                                                            <label>Ảnh CMND/CCCD đã lưu</label>
                                                            <div>
                                                                @if (!string.IsNullOrWhiteSpace(identityFrontImage))
                                                                {
                                                                    <a href="/@identityFrontImage" target="_blank">Xem mặt trước</a>
                                                                }
                                                                @if (!string.IsNullOrWhiteSpace(identityBackImage))
                                                                {
                                                                    <a class="ml-3" href="/@identityBackImage" target="_blank">Xem mặt sau</a>
                                                                }
                                                                @if (Model.IdentityFaceConfidence.HasValue)
                                                                {
                                                                    <span class="text-muted ml-2">Độ khớp khuôn mặt: @Model.IdentityFaceConfidence.Value.ToString("0.##")</span>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-12 mb-4">
                                            <div class="js-form-message">
                                                <label>Số điện thoại</label>
                                                <input type="text" class="form-control rounded-0 pl-3 placeholder-color-3" name="Phone" value="@Model.Phone" @identityLockedAttr>
                                            </div>
                                        </div>
                                        <div class="col-md-12 mb-4">
                                            <div class="js-form-message">
                                                <label>Nơi ở</label>
                                                <input type="text" class="form-control rounded-0" name="Adress" value="@Model.Adress" @identityLockedAttr>
                                            </div>
                                        </div>
                                        <div class="col-md-12 mb-4">
                                            <div class="js-form-message">
                                                <label>Gmail nhận thông báo</label>
                                                <input type="email" class="form-control rounded-0" name="NotificationEmail" value="@(string.IsNullOrWhiteSpace(Model.NotificationEmail) ? Model.Email : Model.NotificationEmail)" @identityLockedAttr>
                                            </div>
                                        </div>
                                        <div class="ml-3">
                                            <a href="javascript:void(0)" onclick="ChangeUserProfile()" class="btn btn-wide btn-dark text-white rounded-0 transition-3d-hover height-60 width-390 @(identityProfileLocked ? "disabled" : "")" aria-disabled="@identityProfileLocked.ToString().ToLowerInvariant()">Lưu thông tin</a>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>


                        <div class="pl-md-5 pl-lg-9 space-bottom-2 space-bottom-lg-3">
                            <div class="d-flex align-items-center justify-content-between mb-4 pb-xl-1">
                                <div class="font-weight-medium font-size-22">Bảo mật tài khoản</div>
                                <button class="btn btn-outline-dark rounded-0" type="button" data-toggle="collapse" data-target="#changePass" aria-expanded="false" aria-controls="changePass">
                                    Đổi mật khẩu
                                </button>
                            </div>
                            <form id="changePass" class="collapse">
                                <div class="row">
                                    <div class="col-md-12 mb-4">
                                        <div class="js-form-message">
                                            <label for="exampleFormControlInput5">Mật khẩu hiện tại</label>
                                            <input type="password" class="form-control rounded-0" name="oldPassWord">
                                            <input type="hidden" name="IDUser" value="@Model.IDUser" />
                                        </div>
                                    </div>
                                    <div class="col-md-12 mb-4">
                                        <div class="js-form-message">
                                            <label for="exampleFormControlInput6">Mật khẩu mới</label>
                                            <input type="password" class="form-control rounded-0" name="newPassWorrd">
                                        </div>
                                    </div>
                                    <div class="col-md-12 mb-5">
                                        <div class="js-form-message">
                                            <label for="exampleFormControlInput7">Nhập lại mật khẩu mới</label>
                                            <input type="password" class="form-control rounded-0" name="confinrmPass">
                                        </div>
                                    </div>
                                    <div class="ml-3">
                                        <a href="javascript:void(0)" onclick="ChangePass()" class="btn btn-wide btn-dark text-white rounded-0 transition-3d-hover height-60 width-390">Lưu thay đổi</a>
                                    </div>
                                </div>
                            </form>
                        </div>


                    </div>
                </div>
            </div>
    </main>
}
else
{
    <main id="content">
        <div class="container py-6">
            <h1 class="font-size-7 mb-3">Thông tin cá nhân</h1>
            <p class="font-size-2 text-gray-700">Bạn cần đăng nhập để xem và cập nhật thông tin cá nhân.</p>
            <a href="/dang-nhap" class="btn btn-dark rounded-0">Đăng nhập</a>
        </div>
    </main>
}
<!-- ====== MAIN CONTENT ===== -->
<!-- ====== END MAIN CONTENT ===== -->
