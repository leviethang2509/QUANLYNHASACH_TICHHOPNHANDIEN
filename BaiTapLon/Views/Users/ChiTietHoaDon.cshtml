@model Mood.EF2.Orders
@using X.PagedList.Mvc;
@{
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
    var hoaDonSanPham = (X.PagedList.IPagedList<Mood.HoaDonModel.ChiTietHoaDon>)ViewBag.hoaDonSanPham;
    var total = ViewBag.priceTotol;

}

@section jsFooter{
    
<script src="~/Content/libs/commonjs/userProfileCommon.js"></script>
    }
<!-- ====== MAIN CONTENT ===== -->
<main id="content" class="bg-app text-main py-5">
    <div class="container">
        <div class="py-4 py-lg-5 text-center">
            <h5 class="font-weight-medium font-size-6 text-main mb-1">Chi Tiết Đơn Hàng</h5>
            <span class="text-muted font-size-2">Theo dõi và quản lý thông tin giao dịch của bạn</span>
        </div>
        <div class="max-width-890 mx-auto">
            <div class="card bg-card border-color shadow-md rounded-md overflow-hidden">
                <div class="p-4 p-md-5">
                    
                    <!-- Order Overview Header -->
                    <div class="border-bottom border-color mb-4 pb-4">
                        <div class="row text-center text-md-left">
                            <div class="col-md-3 mb-3 mb-md-0">
                                <span class="d-block text-muted font-size-2 mb-1">Mã đơn hàng</span>
                                <span class="font-weight-bold font-size-4 text-main">#@Model.IDOder</span>
                            </div>
                            <div class="col-md-3 mb-3 mb-md-0">
                                <span class="d-block text-muted font-size-2 mb-1">Ngày lập đơn</span>
                                <span class="font-weight-medium text-main">@(string.Format("{0:dd/MM/yyyy}", Model.NgayTao))</span>
                            </div>
                            <div class="col-md-3 mb-3 mb-md-0">
                                <span class="d-block text-muted font-size-2 mb-1">Tổng giá trị</span>
                                <span class="font-weight-bold text-primary">@total.ToString("N0")đ</span>
                            </div>
                            <div class="col-md-3">
                                <span class="d-block text-muted font-size-2 mb-1">Thanh toán</span>
                                <span class="font-weight-medium text-main">@Model.DeliveryPaymentMethod</span>
                            </div>
                        </div>
                    </div>

                    <!-- Order Details Items -->
                    <div class="border-bottom border-color mb-4 pb-4">
                        <h6 class="font-size-3 font-weight-bold mb-3 text-main"><i class="fas fa-list mr-2 text-primary"></i>Danh sách sản phẩm</h6>
                        <div class="space-y-3">
                            @foreach (var item in hoaDonSanPham)
                            {
                                var price_deal = (int)(item.Price * (item.Quanlity));
                                <div class="d-flex justify-content-between align-items-center py-2 px-3 bg-app rounded-md border border-color hover-up">
                                    <div class="d-flex align-items-baseline">
                                        <div>
                                            <h6 class="font-size-2 font-weight-medium mb-1 text-main">@item.Name</h6>
                                            <span class="font-size-1 text-muted"><i class="fas fa-feather-alt mr-1"></i> @item.TacGia &bull; Bìa Mềm</span>
                                        </div>
                                        <span class="font-size-2 font-weight-medium text-primary ml-4">x @item.Quanlity</span>
                                    </div>
                                    <span class="font-weight-bold font-size-2 text-main">@price_deal.ToString("N0")đ</span>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Payment & Delivery Details -->
                    <div class="border-bottom border-color mb-4 pb-4">
                        <h6 class="font-size-3 font-weight-bold mb-3 text-main"><i class="fas fa-info-circle mr-2 text-primary"></i>Thông tin vận chuyển</h6>
                        <ul class="list-unstyled mb-0 space-y-2">
                            <li class="d-flex justify-content-between py-1">
                                <span class="text-muted font-size-2">Tiền hàng:</span>
                                <span class="font-weight-medium text-main font-size-2">@total.ToString("N0")đ</span>
                            </li>
                            <li class="d-flex justify-content-between py-1 align-items-center">
                                <span class="text-muted font-size-2">Trạng thái duyệt:</span>
                                <span>
                                    @if (Model.Status == 0)
                                    {
                                        <span class="badge badge-primary">Chờ duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-success">Đã duyệt</span>
                                    }
                                </span>
                            </li>
                            <li class="d-flex justify-content-between py-1 align-items-center">
                                <span class="text-muted font-size-2">Tiến độ giao hàng:</span>
                                <span>
                                    @if (Model.GiaoHang == 2)
                                    {
                                        if (Model.NhanHang == 1)
                                        {
                                            <span class="badge badge-success">Đã hoàn tất</span>
                                        }
                                        else if (Model.NhanHang == 2)
                                        {
                                            <span class="badge badge-danger">Trả Lại</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-info">Đang Giao Hàng</span>
                                        }
                                    }
                                    else if (Model.GiaoHang == 1)
                                    {
                                        <span class="badge badge-warning">Chờ xuất kho</span>
                                    }
                                    else
                                    {
                                        if (Model.GiaoHang == 0)
                                        {
                                            <span class="badge badge-primary">Chờ đóng gói</span>
                                        }
                                        if (Model.GiaoHang == 2)
                                        {
                                            <span class="badge badge-primary">Đã Xuất Kho</span>
                                        }
                                    }
                                </span>
                            </li>
                            <li class="d-flex justify-content-between py-1 border-top border-color pt-2">
                                <span class="font-weight-bold text-main font-size-2">Tổng thanh toán:</span>
                                <span class="font-weight-bold text-primary font-size-3">@total.ToString("N0")đ</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Addresses -->
                    <div class="border-bottom border-color mb-4 pb-4">
                        <div class="row">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <h6 class="font-weight-bold font-size-2 text-main mb-2">
                                    <i class="fas fa-map-marker-alt mr-2 text-muted"></i>Địa chỉ thanh toán
                                </h6>
                                <address class="mb-0 bg-app p-3 rounded-md border border-color font-size-2 text-muted" style="min-height: 80px;">
                                    @Model.ShipAddress
                                </address>
                            </div>
                            <div class="col-md-6">
                                <h6 class="font-weight-bold font-size-2 text-main mb-2">
                                    <i class="fas fa-truck mr-2 text-muted"></i>Địa chỉ nhận hàng
                                </h6>
                                <address class="mb-0 bg-app p-3 rounded-md border border-color font-size-2 text-muted" style="min-height: 80px;">
                                    @Model.ShipAddress
                                </address>
                            </div>
                        </div>
                    </div>

                    <!-- Interactive Confirmation Alert -->
                    <div class="bg-app p-3 rounded-md border border-color d-flex flex-column flex-md-row align-items-md-center justify-content-between">
                        <div class="mb-3 mb-md-0 pr-md-4">
                            <span class="d-block text-main font-weight-medium font-size-2 mb-1">Xác nhận nhận hàng</span>
                            <span class="text-muted font-size-1 d-block">Vui lòng bấm nút xác nhận khi đã nhận được sách để hệ thống cập nhật trạng thái hoàn tất đơn hàng.</span>
                        </div>
                        @if (Model.GiaoHang == 2 && Model.NhanHang == 0)
                        {
                            <button class="success_order btn btn-primary rounded-md font-weight-medium px-4 py-2 hover-up shadow-sm" data-id="@Model.IDOder">
                                <i class="fas fa-check-circle mr-2"></i>Đã nhận hàng
                            </button>
                        }
                    </div>
                    
                </div>
            </div>
            
            <div class="text-center mt-4">
                <a href="/danh-sach-don-hang-@(Model.IDUser)" class="btn btn-outline-primary rounded-md px-4 py-2">
                    <i class="fas fa-arrow-left mr-2"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</main>
<!-- ====== END MAIN CONTENT ===== -->

