<div id="registerFacePanel" class="face-auth-modal" hidden>
    <div class="face-auth-dialog card border-color shadow-lg p-0" role="dialog" aria-modal="true" aria-labelledby="registerFaceTitle">
        <div class="face-auth-header bg-primary text-white p-3 d-flex justify-content-between align-items-center">
            <h3 id="registerFaceTitle" class="face-auth-title text-white mb-0 font-size-3"><i class="fas fa-camera mr-1"></i> Xác thực khuôn mặt</h3>
            <button id="closeRegisterFace" type="button" class="face-auth-close text-white border-0 bg-transparent font-size-5" aria-label="Đóng">&times;</button>
        </div>
        <div class="face-auth-body p-4 text-center bg-card text-main">
            <div class="face-scanner-box mx-auto mb-3" style="max-width: 320px;">
                <div class="face-scanner-line"></div>
                <video id="registerFaceVideo" class="face-auth-video w-100 rounded-lg" style="transform: scaleX(-1);" autoplay muted playsinline></video>
            </div>
            <div id="registerFaceStatus" class="font-size-2 mt-2 text-muted"></div>
            <div class="face-auth-actions d-flex justify-content-center mt-3">
                <button id="registerFaceButton" type="button" class="btn py-3 rounded-md btn-primary mr-2"><i class="fas fa-user-check mr-1"></i> Xác thực khuôn mặt</button>
                <button type="button" class="btn py-3 rounded-md btn-outline-secondary" data-face-close="closeRegisterFace">Đóng</button>
            </div>
        </div>
    </div>
</div>
<script src="/Scripts/FaceCapture.js"></script>
<script>
    (function () {
        function setStatus(id, message, isError) {
            var element = document.getElementById(id);
            if (!element) return;
            element.textContent = message || '';
            element.className = isError ? 'font-size-2 mt-2 text-danger' : 'font-size-2 mt-2 text-success';
        }

        function initFaceLogin(panelId, showButtonId, closeButtonId, videoId, buttonId, statusId, usernameId) {
            var panel = document.getElementById(panelId);
            var showButton = document.getElementById(showButtonId);
            var closeButton = document.getElementById(closeButtonId);
            var video = document.getElementById(videoId);
            var button = document.getElementById(buttonId);
            var username = document.getElementById(usernameId);
            if (!panel || !showButton || !closeButton || !video || !button || !username || !window.FaceCapture) return;

            var stream = null;
            var challengeToken = null;
            var challengeInstruction = null;
            var actionCheckTimer = null;
            var actionCheckAttempts = 0;
            var actionMatched = false;

            function openPanel() {
                panel.hidden = false;
                document.body.classList.add('face-auth-modal-open');
            }

            function closePanel() {
                clearActionCheckTimer();
                FaceCapture.stopCamera(stream);
                stream = null;
                challengeToken = null;
                challengeInstruction = null;
                actionMatched = false;
                panel.hidden = true;
                document.body.classList.remove('face-auth-modal-open');
                setStatus(statusId, '', false);
            }

            function clearActionCheckTimer() {
                if (actionCheckTimer) {
                    clearTimeout(actionCheckTimer);
                    actionCheckTimer = null;
                }
            }

            function loadChallenge() {
                var form = new FormData();
                form.append('purpose', 'Login');
                return fetch('/FaceAuth/CreateChallenge', {
                    method: 'POST',
                    body: form,
                    credentials: 'same-origin'
                }).then(function (response) { return response.json(); })
                    .then(function (result) {
                        if (!result || !result.success) {
                            throw new Error('Không thể tạo yêu cầu xác thực.');
                        }

                        challengeToken = result.token;
                        challengeInstruction = result.instruction;
                        actionMatched = result.actionRequired === false;
                        setStatus(
                            statusId,
                            actionMatched ? 'Camera đã sẵn sàng. Bấm nhận diện để đăng nhập.' : 'Yêu cầu: ' + challengeInstruction + '.',
                            false
                        );
                    });
            }

            function checkActionFrame() {
                return FaceCapture.captureBlob(video)
                    .then(function (blob) {
                        return FaceCapture.uploadFace('/FaceAuth/CheckChallengeAction', blob, {
                            purpose: 'Login',
                            challengeToken: challengeToken,
                            userName: username.value
                        });
                    });
            }

            function startActionCheckLoop() {
                clearActionCheckTimer();
                actionCheckAttempts = 0;
                actionMatched = false;
                button.disabled = true;

                function tick() {
                    if (!stream || !challengeToken) return;
                    actionCheckAttempts += 1;
                    setStatus(statusId, 'Yêu cầu: ' + challengeInstruction + '. Đang tự kiểm tra hành động...', false);
                    checkActionFrame()
                        .then(function (result) {
                            if (result && result.actionMatched) {
                                actionMatched = true;
                                button.disabled = false;
                                setStatus(statusId, 'Đã nhận diện đúng hành động. Giữ mặt trong khung rồi bấm Nhận diện và đăng nhập.', false);
                                return;
                            }

                            if (actionCheckAttempts >= 15) {
                                button.disabled = false;
                                setStatus(statusId, 'Chưa nhận diện đúng hành động. Vui lòng làm lại hoặc bấm nhận diện để thử tiếp.', true);
                                return;
                            }

                            actionCheckTimer = setTimeout(tick, 700);
                        })
                        .catch(function () {
                            if (actionCheckAttempts >= 15) {
                                button.disabled = false;
                                setStatus(statusId, 'Không thể kiểm tra hành động. Vui lòng thử lại.', true);
                                return;
                            }

                            actionCheckTimer = setTimeout(tick, 900);
                        });
                }

                actionCheckTimer = setTimeout(tick, 800);
            }

            function refreshChallengeAfterFailure() {
                challengeToken = null;
                challengeInstruction = null;
                actionMatched = false;
                if (!stream) return;
                loadChallenge()
                    .then(function () {
                        setStatus(statusId, 'Yêu cầu mới: ' + challengeInstruction + '. Hệ thống sẽ tự kiểm tra hành động lại.', false);
                        startActionCheckLoop();
                    })
                    .catch(function () {
                        setStatus(statusId, 'Không thể tạo yêu cầu xác thực mới. Vui lòng đóng và thử lại.', true);
                    });
            }

            function runFaceLogin(isAuto) {
                if (!username.value) {
                    setStatus(statusId, 'Vui lòng nhập tài khoản trước khi xác thực khuôn mặt.', true);
                    return;
                }

                if (!challengeToken && !actionMatched) {
                    setStatus(statusId, 'Vui lòng mở lại camera để nhận yêu cầu xác thực mới.', true);
                    return;
                }

                if (!actionMatched) {
                    startActionCheckLoop();
                    return;
                }

                clearActionCheckTimer();
                button.disabled = true;
                setStatus(statusId, isAuto ? 'Đang tự xác thực khuôn mặt...' : 'Đang xác thực khuôn mặt...', false);

                FaceCapture.captureBlob(video)
                    .then(function (blob) {
                        return FaceCapture.uploadFace('/FaceAuth/AuthenticateFaceLogin', blob, {
                            userName: username.value,
                            challengeToken: challengeToken
                        });
                    })
                    .then(function (result) {
                        if (result && result.success) {
                            setStatus(statusId, 'Đăng nhập thành công.', false);
                            FaceCapture.stopCamera(stream);
                            window.location.href = result.redirectUrl || '/Home/TrangChu';
                            return;
                        }

                        setStatus(statusId, (result && (result.error || result.message)) || 'Đăng nhập bằng khuôn mặt thất bại.', true);
                        button.disabled = false;
                    })
                    .catch(function () {
                        setStatus(statusId, 'Không thể chụp hoặc gửi ảnh khuôn mặt.', true);
                    })
                    .then(function () {
                        button.disabled = false;
                    });
            }

            showButton.addEventListener('click', function () {
                openPanel();
                if (!username.value) {
                    setStatus(statusId, 'Vui lòng nhập tài khoản trước khi đăng nhập bằng khuôn mặt.', true);
                    username.focus();
                    return;
                }

                setStatus(statusId, 'Đang mở camera...', false);

                if (stream) return;
                FaceCapture.requestCameraPermission(document.getElementById(statusId))
                    .then(function () {
                        setStatus(statusId, 'Đang tạo yêu cầu xác thực...', false);
                        return loadChallenge();
                    })
                    .then(function () {
                        return FaceCapture.startCamera(video, document.getElementById(statusId));
                    })
                    .then(function (cameraStream) {
                        stream = cameraStream;
                        if (actionMatched) {
                            button.disabled = false;
                            setStatus(statusId, 'Camera đã sẵn sàng. Bấm nhận diện để đăng nhập.', false);
                            return;
                        }

                        setStatus(statusId, 'Yêu cầu: ' + challengeInstruction + '. Hệ thống sẽ tự nhận diện khi bạn làm đúng hành động.', false);
                        startActionCheckLoop();
                    }).catch(function () {
                        setStatus(statusId, 'Không thể mở camera hoặc tạo yêu cầu xác thực.', true);
                    });
            });

            closeButton.addEventListener('click', closePanel);
            panel.addEventListener('click', function (event) {
                if (event.target === panel || event.target.getAttribute('data-face-close') === closeButtonId) {
                    closePanel();
                }
            });

            button.addEventListener('click', function () {
                runFaceLogin(false);
            });

            window.addEventListener('beforeunload', function () {
                FaceCapture.stopCamera(stream);
            });
        }

        initFaceLogin('faceLoginPanel', 'showFaceLogin', 'closeFaceLogin', 'faceLoginVideo', 'faceLoginButton', 'faceLoginStatus', 'loginUserName');
        initFaceLogin('faceLoginPanelMobile', 'showFaceLoginMobile', 'closeFaceLoginMobile', 'faceLoginVideoMobile', 'faceLoginButtonMobile', 'faceLoginStatusMobile', 'loginUserNameMobile');
    })();
</script>
