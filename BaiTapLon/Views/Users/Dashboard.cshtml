
@{
    
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
}

@model Mood.EF2.User
@using BaiTapLon.Common;
@{
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
    var session = (UserLogin)Session[Constant.USER_SESSION];
}
@section jsFooter{
    <script src="~/Content/libs/commonjs/userProfileCommon.js"></script>
}
@if (session != null)
{
    <main id="content" class="bg-app text-main py-5">
        <div class="container">
            <div class="row">
                <div class="col-md-3 border-right border-color mb-5">
                    <h6 class="font-weight-medium font-size-5 pt-3 mb-4 text-main">Thông tin tài khoản</h6>
                    <div class="tab-wrapper card shadow-sm p-3 bg-card border-color">
                        <ul class="my__account-nav nav flex-column mb-0" role="tablist" id="pills-tab">
                            <li class="nav-item mx-0 py-1">
                                <a class="nav-link d-flex align-items-center px-2 text-main hover-up rounded active bg-primary-light" href="tong-quan-@session.userId">
                                    <i class="fas fa-th-large mr-2 text-primary"></i>
                                    <span class="font-weight-medium text-primary">Tổng quan</span>
                                </a>
                            </li>
                            <li class="nav-item mx-0 py-1">
                                <a class="nav-link d-flex align-items-center px-2 text-main hover-up rounded" href="/danh-sach-don-hang-@session.userId">
                                    <i class="fas fa-shopping-bag mr-2 text-muted"></i>
                                    <span class="text-main">Đơn hàng</span>
                                </a>
                            </li>
                            <li class="nav-item mx-0 py-1">
                                <a class="nav-link d-flex align-items-center px-2 text-main hover-up rounded" href="/tin-nhan-@session.userId">
                                    <i class="fas fa-bell mr-2 text-muted"></i>
                                    <span class="text-main">Thông báo <span class="badge badge-primary badge-pill ml-auto">@session.tolMes</span></span>
                                </a>
                            </li>
                            <li class="nav-item mx-0 py-1">
                                <a class="nav-link d-flex align-items-center px-2 text-main hover-up rounded" href="/phan-hoi-@session.userId">
                                    <i class="fas fa-comment-alt mr-2 text-muted"></i>
                                    <span class="text-main">Phản Hồi <span class="badge badge-info badge-pill ml-auto">@session.tolRep</span></span>
                                </a>
                            </li>
                            <li class="nav-item mx-0 py-1">
                                <a class="nav-link d-flex align-items-center px-2 text-main hover-up rounded" href="/thong-tin-ca-nhan-@session.userId">
                                    <i class="fas fa-user mr-2 text-muted"></i>
                                    <span class="text-main">Thông tin cá nhân</span>
                                </a>
                            </li>
                            <li class="nav-item mx-0 py-1">
                                <a class="nav-link d-flex align-items-center px-2 text-main hover-up rounded" href="/yeu-thich-@session.userId">
                                    <i class="fas fa-heart mr-2 text-muted"></i>
                                    <span class="text-main">Sách yêu thích</span>
                                </a>
                            </li>
                            <li class="nav-item mx-0 py-1 border-top border-color mt-2 pt-2">
                                <a class="nav-link d-flex align-items-center px-2 text-danger hover-up rounded" href="/Users/Logout">
                                    <i class="fas fa-sign-out-alt mr-2"></i>
                                    <span>Thoát</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="col-md-9">
                    <div class="tab-content" id="pills-tabContent">
                        <div class="tab-pane fade show active" id="pills-one-example1" role="tabpanel" aria-labelledby="pills-one-example1-tab">
                            <div class="pl-md-4">
                                <h6 class="font-weight-medium font-size-6 mb-4 text-main border-bottom pb-2 border-color">Trang tổng quan</h6>
                                <div class="mb-4">
                                    <span class="font-size-22 text-main">Xin Chào <strong>@session.name</strong></span>
                                    <span class="font-size-2 ml-2">(<a class="text-danger font-weight-bold" href="/Users/Logout">Đăng Xuất</a>)</span>
                                </div>
                                <div class="mb-4">
                                    <p class="mb-0 font-size-2 text-muted">Từ trang tổng quan tài khoản của mình, bạn có thể xem các <span class="text-main font-weight-bold">đơn đặt hàng gần đây,</span> quản lý <span class="text-main font-weight-bold">địa chỉ giao hàng và thanh toán,</span> cũng như chỉnh sửa <span class="text-main font-weight-bold">mật khẩu và chi tiết tài khoản của mình.</span></p>
                                </div>
                                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
                                    <div class="col mb-4">
                                        <div class="card p-4 bg-card border-color shadow-sm rounded-md text-center h-100 hover-up">
                                            <a href="/danh-sach-don-hang-@session.userId" class="d-inline-flex align-items-center justify-content-center bg-app rounded-circle p-3 mb-3 mx-auto" style="width: 70px; height: 70px;">
                                                <i class="fas fa-shopping-bag text-primary font-size-5"></i>
                                            </a>
                                            <div class="font-weight-medium text-main font-size-3">Đơn Hàng</div>
                                        </div>
                                    </div>
                                    <div class="col mb-4">
                                        <div class="card p-4 bg-card border-color shadow-sm rounded-md text-center h-100 hover-up">
                                            <a href="/tin-nhan-@session.userId" class="d-inline-flex align-items-center justify-content-center bg-app rounded-circle p-3 mb-3 mx-auto" style="width: 70px; height: 70px;">
                                                <i class="fas fa-bell text-primary font-size-5"></i>
                                            </a>
                                            <div class="font-weight-medium text-main font-size-3">Thông Báo <span class="badge badge-primary ml-1">@session.tolMes</span></div>
                                        </div>
                                    </div>
                                    <div class="col mb-4">
                                        <div class="card p-4 bg-card border-color shadow-sm rounded-md text-center h-100 hover-up">
                                            <a href="/phan-hoi-@session.userId" class="d-inline-flex align-items-center justify-content-center bg-app rounded-circle p-3 mb-3 mx-auto" style="width: 70px; height: 70px;">
                                                <i class="fas fa-comment-alt text-primary font-size-5"></i>
                                            </a>
                                            <div class="font-weight-medium text-main font-size-3">Phản Hồi <span class="badge badge-info ml-1">@session.tolRep</span></div>
                                        </div>
                                    </div>
                                    <div class="col mb-4">
                                        <div class="card p-4 bg-card border-color shadow-sm rounded-md text-center h-100 hover-up">
                                            <a href="/thong-tin-ca-nhan-@session.userId" class="d-inline-flex align-items-center justify-content-center bg-app rounded-circle p-3 mb-3 mx-auto" style="width: 70px; height: 70px;">
                                                <i class="fas fa-user text-primary font-size-5"></i>
                                            </a>
                                            <div class="font-weight-medium text-main font-size-3">Thông tin cá nhân</div>
                                        </div>
                                    </div>
                                    <div class="col mb-4">
                                        <div class="card p-4 bg-card border-color shadow-sm rounded-md text-center h-100 hover-up">
                                            <a href="/yeu-thich-@session.userId" class="d-inline-flex align-items-center justify-content-center bg-app rounded-circle p-3 mb-3 mx-auto" style="width: 70px; height: 70px;">
                                                <i class="fas fa-heart text-primary font-size-5"></i>
                                            </a>
                                            <div class="font-weight-medium text-main font-size-3">Sách yêu thích</div>
                                        </div>
                                    </div>
                                    <div class="col mb-4">
                                        <div class="card p-4 bg-card border-color shadow-sm rounded-md text-center h-100 hover-up">
                                            <a href="/Users/Logout" class="d-inline-flex align-items-center justify-content-center bg-app rounded-circle p-3 mb-3 mx-auto" style="width: 70px; height: 70px;">
                                                <i class="fas fa-sign-out-alt text-danger font-size-5"></i>
                                            </a>
                                            <div class="font-weight-medium text-danger font-size-3">Thoát</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>



                        
                    </div>
                </div>
            </div>
        </div>
    </main>
}
<!-- ====== MAIN CONTENT ===== -->
<!-- ====== END MAIN CONTENT ===== -->
