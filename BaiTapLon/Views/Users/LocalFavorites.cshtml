@{
    ViewBag.Title = "Sách yêu thích";
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
}

<main id="content">
    <div class="container py-6">
        <div class="d-md-flex justify-content-between align-items-center mb-5">
            <div>
                <h1 class="font-size-7 mb-2">Sách yêu thích</h1>
                <p class="font-size-2 text-gray-700 mb-0">Danh sách này được lưu trên trình duyệt của máy hiện tại, không cần đăng nhập.</p>
            </div>
            <a href="/dang-nhap" class="btn btn-outline-dark rounded-0 mt-3 mt-md-0">Đăng nhập để đồng bộ tài khoản</a>
        </div>
        <div id="localFavoriteList" class="row"></div>
        <div id="localFavoriteEmpty" style="display:none;">
            <img src="~/DataImage/ic-menu-faq-4.png" width="100" height="100" alt="" /><br />
            <span>Hiện tại bạn chưa có sách yêu thích nào trên máy này.</span>
        </div>
    </div>
</main>
