@model X.PagedList.IPagedList<Mood.EF2.Sanpham>
@using X.PagedList.Mvc;
@using BaiTapLon.Common;
@{
    ViewBag.Title = "Sách yêu thích";
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
    var session = (UserLogin)Session[Constant.USER_SESSION];
    var ownerName = (ViewBag.FavoriteOwnerName as string) ?? (session != null ? session.name : string.Empty);
    var ownerUserName = (ViewBag.FavoriteOwnerUserName as string) ?? (session != null ? session.userName : string.Empty);
    var favoriteCount = Model != null ? Model.TotalItemCount : 0;
}

@if (session != null)
{
    <div class="right-sidebar woocommerce-cart">
        <div class="page-header border-bottom">
            <div class="container">
                <div class="d-md-flex justify-content-between align-items-center py-4">
                    <h1 class="page-title font-size-3 font-weight-medium m-0 text-lh-lg">SÁCH YÊU THÍCH</h1>
                    <nav class="woocommerce-breadcrumb font-size-2">
                        <a href="/Home/TrangChu" class="h-primary">Trang Chủ</a>
                        <span class="breadcrumb-separator mx-1"><i class="fas fa-angle-right"></i></span>
                        <a href="/tong-quan-@session.userId" class="h-primary">Tài khoản</a>
                        <span class="breadcrumb-separator mx-1"><i class="fas fa-angle-right"></i></span>Sách yêu thích
                    </nav>
                </div>
            </div>
        </div>

        <div class="site-content bg-punch-light overflow-hidden" id="content">
            <div class="container">
                <div class="row">
                    <div class="col-md-3 border-right bg-white">
                        <h6 class="font-weight-medium font-size-7 pt-5 pt-lg-8 mb-2 mb-lg-3">Thông tin tài khoản</h6>
                        <div class="font-size-2 text-gray-700 mb-5">
                            <div class="font-weight-medium">@ownerName</div>
                            <div>@ownerUserName</div>
                            <div class="text-success">Đã đăng nhập</div>
                        </div>
                        <ul class="my__account-nav nav flex-column mb-0">
                            <li class="nav-item mx-0"><a class="nav-link d-flex align-items-center px-0" href="/tong-quan-@session.userId"><span class="font-weight-normal text-gray-600">Tổng quan</span></a></li>
                            <li class="nav-item mx-0"><a class="nav-link d-flex align-items-center px-0" href="/danh-sach-don-hang-@session.userId"><span class="font-weight-normal text-gray-600">Đơn hàng</span></a></li>
                            <li class="nav-item mx-0"><a class="nav-link d-flex align-items-center px-0" href="/tin-nhan-@session.userId"><span class="font-weight-normal text-gray-600">Thông báo (@session.tolMes)</span></a></li>
                            <li class="nav-item mx-0"><a class="nav-link d-flex align-items-center px-0" href="/phan-hoi-@session.userId"><span class="font-weight-normal text-gray-600">Phản hồi (@session.tolRep)</span></a></li>
                            <li class="nav-item mx-0"><a class="nav-link d-flex align-items-center px-0" href="/thong-tin-ca-nhan-@session.userId"><span class="font-weight-normal text-gray-600">Thông tin cá nhân</span></a></li>
                            <li class="nav-item mx-0"><a class="nav-link d-flex align-items-center px-0 active" href="/yeu-thich-@session.userId"><span class="font-weight-normal text-gray-600">Sách yêu thích</span></a></li>
                            <li class="nav-item mx-0"><a class="nav-link d-flex align-items-center px-0" href="/Users/Logout"><span class="font-weight-normal text-gray-600">Thoát</span></a></li>
                        </ul>
                    </div>

                    <div class="col-md-9">
                        <div class="pt-5 pl-md-5 pt-lg-8 pl-lg-9 space-bottom-lg-2 mb-lg-4">
                            <header class="entry-header space-bottom-1 mb-2">
                                <h1 class="entry-title font-size-7">Sách yêu thích của bạn: @favoriteCount sản phẩm</h1>
                                <div class="font-size-2 text-gray-700">Danh sách này được lưu riêng cho từng tài khoản.</div>
                            </header>

                            <form method="get" class="mb-5">
                                <div class="input-group">
                                    <input class="form-control rounded-0" name="searhString" value="@ViewBag.SearchString" placeholder="Tìm theo tên sách hoặc tác giả" />
                                    <div class="input-group-append">
                                        <button class="btn btn-dark rounded-0" type="submit">Tìm</button>
                                    </div>
                                </div>
                            </form>

                            @if (Model != null && Model.Count > 0)
                            {
                                <div class="woocommerce">
                                    <form class="woocommerce-cart-form table-responsive" action="#" method="post">
                                        <table class="shop_table shop_table_responsive cart woocommerce-cart-form__contents">
                                            <thead>
                                                <tr>
                                                    <th class="product-name">Tên Sản Phẩm</th>
                                                    <th class="product-price">Giá Tiền</th>
                                                    <th class="product-quantity">Tình Trạng</th>
                                                    <th class="product-subtotal">Thao Tác</th>
                                                    <th class="product-remove">&nbsp;</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in Model)
                                                {
                                                    var priceSale = item.PriceSale ?? 0;
                                                    var priceDeal = item.GiaTien - item.GiaTien / 100 * priceSale;
                                                    var url = "/chi-tiet/" + item.MetaTitle + "-" + item.IDContent;
                                                    <tr class="woocommerce-cart-form__cart-item cart_item js-favorite-row">
                                                        <td class="product-name" data-title="Product">
                                                            <div class="d-flex align-items-center">
                                                                <a href="@url">
                                                                    <img src="@item.Images" width="80" height="120" class="attachment-shop_thumbnail size-shop_thumbnail wp-post-image" alt="@item.Name">
                                                                </a>
                                                                <div class="ml-3 m-w-200-lg-down">
                                                                    <a href="@url">@item.Name</a>
                                                                    <a href="@url" class="text-gray-700 font-size-2 d-block" tabindex="0">@item.TacGia</a>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td class="product-price" data-title="Price">
                                                            <span class="woocommerce-Price-amount amount">@priceDeal.ToString("N0")đ</span>
                                                        </td>
                                                        <td class="product-quantity" data-title="Status">
                                                            @if (item.Soluong > 0)
                                                            {
                                                                <span class="text-success">Còn hàng</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-danger">Hết hàng</span>
                                                            }
                                                        </td>
                                                        <td class="product-subtotal" data-title="Action">
                                                            <input type="button" class="button btn-dark rounded-0 px-4 py-2" value="Thêm vào giỏ" onclick="addcartHome(@item.IDContent)" />
                                                        </td>
                                                        <td class="product-remove">
                                                            <button type="button" class="btn btn-link p-0 js-favorite-toggle is-favorite" data-icon-only="true" data-product-id="@item.IDContent" aria-label="Bỏ yêu thích" title="Bỏ yêu thích">
                                                                <svg xmlns="http://www.w3.org/2000/svg" width="15px" height="15px">
                                                                    <path fill-rule="evenodd" fill="rgb(22, 22, 25)" d="M15.011,13.899 L13.899,15.012 L7.500,8.613 L1.101,15.012 L-0.012,13.899 L6.387,7.500 L-0.012,1.101 L1.101,-0.012 L7.500,6.387 L13.899,-0.012 L15.011,1.101 L8.613,7.500 L15.011,13.899 Z" />
                                                                </svg>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </form>
                                </div>

                                <nav aria-label="Page navigation">
                                    @Html.PagedListPager(Model, page => Url.Action("Favorites", new { id = session.userId, page = page, searhString = ViewBag.SearchString }),
                                        new PagedListRenderOptions
                                        {
                                            UlElementClasses = new string[] { "pagination pagination__custom justify-content-md-center flex-nowrap flex-md-wrap overflow-auto overflow-md-visble" },
                                            LiElementClasses = new string[] { "flex-shrink-0 flex-md-shrink-1 page-item" },
                                            LinkToPreviousPageFormat = "Trước",
                                            LinkToNextPageFormat = "Kế tiếp",
                                            PageClasses = new string[] { "page-link" }
                                        })
                                </nav>
                            }
                            else
                            {
                                <div class="alert alert-danger" role="alert">
                                    <span>Hiện tại bạn chưa có sách yêu thích nào.</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <main id="content">
        <div class="container py-6">
            <h1 class="font-size-7 mb-3">Sách yêu thích</h1>
            <p class="font-size-2 text-gray-700">Bạn chưa đăng nhập. Vui lòng đăng nhập để xem danh sách sách yêu thích của tài khoản.</p>
            <a href="/dang-nhap" class="btn btn-dark rounded-0">Đăng nhập</a>
        </div>
    </main>
}
