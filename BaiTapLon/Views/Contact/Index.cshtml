@model Mood.EF2.Contact
@{
    ViewBag.Title = "Liên Hệ";
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
    var userLoginContact = (Mood.EF2.User)ViewBag.LoginUser;
    var store = ViewBag.StoreInfo as Mood.EF2.StoreLocation;
    var storeName = store == null || string.IsNullOrWhiteSpace(store.StoreName) ? "Nha sach" : store.StoreName;
    var storeAddress = store == null || string.IsNullOrWhiteSpace(store.Address) ? Model.Content : store.Address;
    var storeEmail = store == null ? null : store.Email;
    var storePhone = store == null ? null : store.Phone;
    var mapSrc = store != null && store.Latitude != 0 && store.Longitude != 0
        ? "https://www.google.com/maps?q=" + store.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture) + "," + store.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture) + "&output=embed"
        : "https://www.google.com/maps?q=" + HttpUtility.UrlEncode(storeAddress) + "&output=embed";
}

@section JsFooter{
<script src="~/Content/Home/js/Controller/contactController.js"></script>
}


 <!-- ====== MAIN CONTENT ===== -->
<main id="content" class="bg-app text-main py-5">
    <div class="py-3 py-lg-7">
        <h6 class="font-weight-medium font-size-7 text-center my-1">Liên hệ chúng tôi</h6>
    </div>
    <iframe src="@mapSrc"  height="500" style="border:0; width:100%;" allowfullscreen="" loading="lazy"></iframe>
    <div class="container">
        <div class="space-bottom-1 space-bottom-lg-2">
            <div class="pb-4">
                <div class="col-lg-8 mx-auto">
                    <div class="card bg-card border-color shadow-lg mt-n10 mt-md-n13 p-4 p-md-5" style="border-radius: var(--radius-lg) !important; background-color: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
                        <div class="ml-xl-4">
                            <div class="mb-4 mb-lg-7">
                                <h6 class="font-weight medium font-size-10 mb-4 mb-lg-7">Thông tin liên lạc</h6>
                                <p class="font-weight-medium font-italic">
                                    Chúng tôi sẽ trả lời bất kỳ câu hỏi nào bạn có thể có về bán hàng trực tuyến, quyền hoặc dịch vụ hợp tác của chúng tôi ngay tại đây.
                                </p>
                            </div>
                            <div class="mb-4 mb-lg-8">
                                <div class="row">
                                    <div class="col-md-6">
                                        <h6 class="font-weight-medium font-size-4 mb-4">@storeName</h6>
                                        <address class="font-size-2 mb-5">
                                            <span class="mb-2 font-weight-normal text-dark">
                                                Địa chỉ: @storeAddress
                                            </span>
                                        </address>
                                        <div>
                                            @if (!string.IsNullOrWhiteSpace(storeEmail))
                                            {
                                                <a href="mailto:@storeEmail" class="font-size-2 d-block link-black-100 mb-1">Email: @storeEmail</a>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(storePhone))
                                            {
                                                <a href="tel:@storePhone" class="font-size-2 d-block link-black-100">Số điện thoại: @storePhone</a>
                                            }
                                        </div>
                                    </div>
                                   
                                </div>
                            </div>
                            <div class="mb-5 mb-xl-9 pb-xl-1">
                                <h6 class="font-size-4 font-weight-medium">Truyền Thông Xã Hội</h6>
                                <ul class="list-unstyled mb-0 d-flex">
                                    <li class="btn pl-0">
                                        <a class="text-primary hover-up" href="#">
                                            <span class="fab fa-instagram"></span>
                                        </a>
                                    </li>
                                    <li class="btn">
                                        <a class="link-black-100" href="#">
                                            <span class="fab fa-facebook-f"></span>
                                        </a>
                                    </li>
                                    <li class="btn">
                                        <a class="link-black-100" href="#">
                                            <span class="fab fa-youtube"></span>
                                        </a>
                                    </li>
                                    <li class="btn">
                                        <a class="link-black-100" href="#">
                                            <span class="fab fa-twitter"></span>
                                        </a>
                                    </li>
                                    <li class="btn">
                                        <a class="link-black-100" href="#">
                                            <span class="fab fa-pinterest"></span>
                                        </a>
                                    </li>
                                </ul>
                            </div>
                            <div>
                                <h6 class="font-weight-medium font-size-10 mb-3 pb-xl-1">Liên Lạc</h6>
                                <form id="lienheForm" class="js-validate" novalidate="novalidate">
                                    <div class="row">
                                        @if (userLoginContact != null)
                                        {
                                            <!-- Input -->
                                            <div class="col-sm-6 mb-5">
                                                <div class="js-form-message">
                                                    <label for="exampleFormControlInput1">Họ và tên</label>
                                                    <input id="userName" type="text" class="form-control rounded-md border-color bg-card text-main" value="@userLoginContact.Name" name="name" aria-label="Jack Wayley" required="" data-error-class="u-has-error" data-msg="Please enter your name." data-success-class="u-has-success">
                                                    
                                                </div>
                                            </div>
                                        <!-- End Input -->
                                        <!-- Input -->
                                            <div class="col-sm-6 mb-5">
                                                <div class="js-form-message">
                                                    <label for="exampleFormControlInput2">Số điện thoại</label>
                                                    <input id="userPhone" value="@userLoginContact.Phone" class="form-control rounded-md border-color bg-card text-main" name="email" aria-label="jackwayley@gmail.com" required="" data-msg="Please enter a valid email address." data-error-class="u-has-error" data-success-class="u-has-success">
                                                </div>
                                            </div>
                                            <!-- Input -->
                                            <div class="col-sm-6 mb-5">
                                                <div class="js-form-message">
                                                    <label for="exampleFormControlInput1">Địa chỉ</label>
                                                    <input id="userAddress" type="text" class="form-control rounded-md border-color bg-card text-main" value="@userLoginContact.Adress" name="name" aria-label="Jack Wayley" required="" data-error-class="u-has-error" data-msg="Please enter your name." data-success-class="u-has-success">

                                                </div>
                                            </div>
                                        <!-- End Input -->
                                        <!-- Input -->
                                            <div class="col-sm-6 mb-5">
                                                <div class="js-form-message">
                                                    <label for="exampleFormControlInput2">Email</label>
                                                    <input id="userEmail" value="@userLoginContact.Email" class="form-control rounded-md border-color bg-card text-main" name="email" aria-label="jackwayley@gmail.com" required="" data-msg="Please enter a valid email address." data-error-class="u-has-error" data-success-class="u-has-success">
                                                </div>
                                            </div>
                                        <!-- End Input -->
                                            <div class="col-sm-12 mb-5">
                                                <div class="js-form-message">
                                                    <label for="exampleFormControlInput3">Tiêu đề</label>
                                                    <input id="userTieuDe" type="text" class="form-control rounded-md border-color bg-card text-main" name="email" aria-label="jackwayley@gmail.com" required="" data-msg="Please enter a valid email address." data-error-class="u-has-error" data-success-class="u-has-success">
                                                </div>
                                            </div>
                                            <div class="col-sm-12 mb-5">
                                                <div class="js-form-message">
                                                    <div class="input-group flex-column">
                                                        <label for="exampleFormControlInput4">Thông tin chi tiết xin vui lòng! Đánh giá của bạn giúp ích cho những người mua sắm khác.</label>
                                                        <textarea id="userMsg" class="form-control rounded-md border-color bg-card text-main pl-3 font-size-2 placeholder-color-3" rows="6" cols="77" name="text" placeholder="Bạn thích và không thích điều gì?" aria-label="Hi there, I would like to ..." required="" data-msg="Please enter a reason." data-error-class="u-has-error" data-success-class="u-has-success"></textarea>
                                                    </div>
                                                </div>
                                            </div>
                                        <!-- End Input -->
                                        }
                                        else
                                        {
                                            <!-- Input -->
                                            <div class="col-sm-6 mb-5">
                                                <div class="js-form-message">
                                                    <label for="exampleFormControlInput1">Họ và tên</label>
                                                    <input id="userName" type="text" class="form-control rounded-md border-color bg-card text-main" value="" name="name" aria-label="Jack Wayley" required="" data-error-class="u-has-error" data-msg="Please enter your name." data-success-class="u-has-success">
                                                </div>
                                            </div>
                                        <!-- End Input -->
                                            <!-- Input -->
                                            <div class="col-sm-6 mb-5">
                                                <div class="js-form-message">
                                                    <label for="exampleFormControlInput2">Số điện thoại</label>
                                                    <input id="userPhone"  class="form-control rounded-md border-color bg-card text-main" name="email" aria-label="jackwayley@gmail.com" required="" data-msg="Please enter a valid email address." data-error-class="u-has-error" data-success-class="u-has-success">
                                                </div>
                                            </div>
                                            <!-- Input -->
                                            <div class="col-sm-6 mb-5">
                                                <div class="js-form-message">
                                                    <label for="exampleFormControlInput1">Địa chỉ</label>
                                                    <input id="userAddress" type="text" class="form-control rounded-md border-color bg-card text-main"  name="name" aria-label="Jack Wayley" required="" data-error-class="u-has-error" data-msg="Please enter your name." data-success-class="u-has-success">

                                                </div>
                                            </div>
                                        <!-- Input -->
                                            <div class="col-sm-6 mb-5">
                                                <div class="js-form-message">
                                                    <label for="exampleFormControlInput2">Email</label>
                                                    <input id="userEmail" value="" class="form-control rounded-md border-color bg-card text-main" name="email" aria-label="jackwayley@gmail.com" required="" data-msg="Please enter a valid email address." data-error-class="u-has-error" data-success-class="u-has-success">
                                                </div>
                                            </div>
                                        <!-- End Input -->
                                            <div class="col-sm-12 mb-5">
                                                <div class="js-form-message">
                                                    <label for="exampleFormControlInput3">Tiêu đề</label>
                                                    <input id="userTieuDe" type="text" class="form-control rounded-md border-color bg-card text-main" name="email" aria-label="jackwayley@gmail.com" required="" data-msg="Please enter a valid email address." data-error-class="u-has-error" data-success-class="u-has-success">
                                                </div>
                                            </div>
                                            <div class="col-sm-12 mb-5">
                                                <div class="js-form-message">
                                                    <div class="input-group flex-column">
                                                        <label for="exampleFormControlInput4">Thông tin chi tiết xin vui lòng! Đánh giá của bạn giúp ích cho những người mua sắm khác.</label>
                                                        <textarea id="userMsg" class="form-control rounded-md border-color bg-card text-main pl-3 font-size-2 placeholder-color-3" rows="6" cols="77" name="text" placeholder="Bạn thích và không thích điều gì?" aria-label="Hi there, I would like to ..." required="" data-msg="Please enter a reason." data-error-class="u-has-error" data-success-class="u-has-success"></textarea>
                                                    </div>
                                                </div>
                                            </div>
                                        <!-- End Input -->
                                        }
                                        <div class="col d-flex justify-content-lg-start">
                                            <a href="javascript:void(0)" id="btnSend" class="btn btn-wide btn-dark text-white rounded-0 transition-3d-hover height-60">Gửi câu hỏi</a>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
<!-- ====== END MAIN CONTENT ===== -->
