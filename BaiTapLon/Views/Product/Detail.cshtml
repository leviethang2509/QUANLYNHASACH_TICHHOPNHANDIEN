    <!-- ====== END MAIN CONTENT ====== -->
    <script src="/Scripts/FaceCapture.js"></script>
    <script>
        (function () {
            var reviewForm = document.getElementById('productReviewForm');
            var reviewStatus = document.getElementById('productReviewStatus');
            if (reviewForm) {
                reviewForm.addEventListener('submit', function (event) {
                    event.preventDefault();
                    reviewStatus.textContent = 'Đang lưu đánh giá...';
                    fetch('/Product/AddReview', {
                        method: 'POST',
                        body: new FormData(reviewForm),
                        credentials: 'same-origin'
                    }).then(function (response) { return response.json(); })
                        .then(function (result) {
                            reviewStatus.textContent = (result && result.message) || 'Không thể lưu đánh giá.';
                            if (result && result.requireLogin) {
                                setTimeout(function () { window.location.href = '/dang-nhap'; }, 900);
                            } else if (result && result.success) {
                                setTimeout(function () { window.location.reload(); }, 900);
                            }
                        }).catch(function () {
                            reviewStatus.textContent = 'Không thể lưu đánh giá.';
                        });
                });
            }

            var borrowButton = document.getElementById('borrowBookBtn');
            var status = document.getElementById('borrowBookStatus');
            var requestPanel = document.getElementById('rentalRequestPanel');
            var facePanel = document.getElementById('rentalFacePanel');
            var requestDate = document.getElementById('rentalRequestDate');
            var borrowDays = document.getElementById('rentalBorrowDays');
            var identityNumber = document.getElementById('rentalIdentityNumber');
            var identityFullName = document.getElementById('rentalIdentityFullName');
            var rentalProfilePanel = document.getElementById('rentalProfilePanel');
            var closeRentalProfileBtn = document.getElementById('closeRentalProfileBtn');
            var rentalProfileEmail = document.getElementById('rentalProfileEmail');
            var rentalProfileIdentityNumber = document.getElementById('rentalProfileIdentityNumber');
            var rentalProfileIdentityFullName = document.getElementById('rentalProfileIdentityFullName');
            var rentalProfileIdentityFrontFile = document.getElementById('rentalProfileIdentityFrontFile');
            var rentalProfileIdentityBackFile = document.getElementById('rentalProfileIdentityBackFile');
            var rentalProfileStatus = document.getElementById('rentalProfileStatus');
            var ocrRentalProfileBtn = document.getElementById('ocrRentalProfileBtn');
            var saveRentalProfileBtn = document.getElementById('saveRentalProfileBtn');
            var confirmInfoButton = document.getElementById('confirmRentalInfoBtn');
            var cancelInfoButton = document.getElementById('cancelRentalInfoBtn');
            var captureFaceButton = document.getElementById('captureRentalFaceBtn');
            var cancelFaceButton = document.getElementById('cancelRentalFaceBtn');
            var closeFaceButton = document.getElementById('closeRentalFaceBtn');
            var faceVideo = document.getElementById('rentalFaceVideo');
            var faceStatus = document.getElementById('rentalFaceStatus');
            var faceStream = null;
            var rentalChallengeToken = null;
            var rentalChallengeInstruction = null;
            var rentalActionCheckTimer = null;
            var rentalActionCheckAttempts = 0;
            var rentalActionMatched = false;
            var activeStoreName = 'nha sach';
            if (!borrowButton || !status) return;

            function setStatus(message, isError) {
                status.textContent = message;
                status.className = isError ? 'font-size-2 mt-2 text-danger' : 'font-size-2 mt-2 text-success';
            }

            function setFaceStatus(message, isError) {
                if (!faceStatus) return;
                faceStatus.textContent = message;
                faceStatus.className = isError ? 'font-size-2 mt-2 text-danger' : 'font-size-2 mt-2 text-success';
            }

            function updateRentalBadge(count) {
                var badge = document.getElementById('activeRentalCountBadge');
                if (!badge || count === undefined || count === null) return;
                badge.textContent = count;
                if (count > 0) {
                    badge.classList.remove('d-none');
                } else {
                    badge.classList.add('d-none');
                }
            }

            function setRentalProfileStatus(message, isError) {
                if (!rentalProfileStatus) return;
                rentalProfileStatus.textContent = message || '';
                rentalProfileStatus.className = isError ? 'font-size-2 mb-3 text-danger' : 'font-size-2 mb-3 text-success';
            }

            function openRentalProfilePanel(profile) {
                profile = profile || {};
                rentalProfileEmail.value = profile.notificationEmail || '';
                rentalProfileIdentityNumber.value = profile.identityNumber || '';
                rentalProfileIdentityFullName.value = profile.identityFullName || '';
                rentalProfilePanel.hidden = false;
                document.body.classList.add('face-auth-modal-open');
                setRentalProfileStatus('Vui lòng cập nhật Gmail nhận thông báo, số CMND/CCCD và họ tên trước khi mượn.', false);
            }

            function closeRentalProfilePanel() {
                rentalProfilePanel.hidden = true;
                document.body.classList.remove('face-auth-modal-open');
            }

            function openRentalRequestPanel() {
                requestDate.value = today();
                requestPanel.style.display = 'block';
                facePanel.hidden = true;
                setStatus('Thông tin mượn sách đã lấy từ hồ sơ. Bạn chỉ thay đổi được số ngày mượn.', false);
            }

            function checkRentalProfileBeforeBorrow() {
                return fetch('/Rental/RentalProfileStatus', {
                    method: 'GET',
                    credentials: 'same-origin'
                }).then(function (response) { return response.json(); })
                    .then(function (profile) {
                        if (!profile || !profile.success) {
                            setStatus((profile && profile.error) || 'Không thể kiểm tra hồ sơ mượn sách.', true);
                            return;
                        }

                        if (profile.requireUpdate) {
                            openRentalProfilePanel(profile);
                            return;
                        }

                        if (identityNumber) identityNumber.value = profile.identityNumber || '';
                        if (identityFullName) identityFullName.value = profile.identityFullName || '';
                        openRentalRequestPanel();
                    });
            }

            function openFacePanel() {
                facePanel.hidden = false;
                document.body.classList.add('face-auth-modal-open');
            }

            function closeFacePanel(showRequestPanel) {
                clearRentalActionCheckTimer();
                if (window.FaceCapture) FaceCapture.stopCamera(faceStream);
                faceStream = null;
                rentalChallengeToken = null;
                rentalChallengeInstruction = null;
                rentalActionMatched = false;
                facePanel.hidden = true;
                document.body.classList.remove('face-auth-modal-open');
                if (showRequestPanel) {
                    requestPanel.style.display = 'block';
                    setStatus('Đã hủy xác nhận khuôn mặt.', true);
                }
            }

            function clearRentalActionCheckTimer() {
                if (rentalActionCheckTimer) {
                    clearTimeout(rentalActionCheckTimer);
                    rentalActionCheckTimer = null;
                }
            }

            function loadRentalChallenge() {
                var form = new FormData();
                form.append('purpose', 'Rental');
                return fetch('/FaceAuth/CreateChallenge', {
                    method: 'POST',
                    body: form,
                    credentials: 'same-origin'
                }).then(function (response) { return response.json(); })
                    .then(function (result) {
                        if (!result || !result.success) {
                            throw new Error('Không thể tạo yêu cầu xác thực.');
                        }

                        rentalChallengeToken = result.token;
                        rentalChallengeInstruction = result.instruction;
                        rentalActionMatched = false;
                        setFaceStatus('Yêu cầu: ' + rentalChallengeInstruction + '.', false);
                    });
            }

            function checkRentalActionFrame() {
                return FaceCapture.captureBlob(faceVideo)
                    .then(function (blob) {
                        return FaceCapture.uploadFace('/FaceAuth/CheckChallengeAction', blob, {
                            purpose: 'Rental',
                            challengeToken: rentalChallengeToken
                        });
                    });
            }

            function startRentalActionCheckLoop() {
                clearRentalActionCheckTimer();
                rentalActionCheckAttempts = 0;
                rentalActionMatched = false;
                captureFaceButton.disabled = true;

                function tick() {
                    if (!faceStream || !rentalChallengeToken) return;
                    rentalActionCheckAttempts += 1;
                    setFaceStatus('Yêu cầu: ' + rentalChallengeInstruction + '. Đang tự kiểm tra hành động...', false);
                    checkRentalActionFrame()
                        .then(function (result) {
                            if (result && result.actionMatched) {
                                rentalActionMatched = true;
                                captureFaceButton.disabled = false;
                                setFaceStatus('Đã nhận diện đúng hành động. Giữ mặt trong khung rồi bấm Nhận diện và xác nhận.', false);
                                return;
                            }

                            if (rentalActionCheckAttempts >= 15) {
                                captureFaceButton.disabled = false;
                                setFaceStatus('Chưa nhận diện đúng hành động. Vui lòng làm lại hoặc bấm nhận diện để thử tiếp.', true);
                                return;
                            }

                            rentalActionCheckTimer = setTimeout(tick, 700);
                        })
                        .catch(function () {
                            if (rentalActionCheckAttempts >= 15) {
                                captureFaceButton.disabled = false;
                                setFaceStatus('Không thể kiểm tra hành động. Vui lòng thử lại.', true);
                                return;
                            }

                            rentalActionCheckTimer = setTimeout(tick, 900);
                        });
                }

                rentalActionCheckTimer = setTimeout(tick, 800);
            }

            function refreshRentalChallengeAfterFailure() {
                rentalChallengeToken = null;
                rentalChallengeInstruction = null;
                rentalActionMatched = false;
                if (!faceStream) return;
                loadRentalChallenge()
                    .then(function () {
                        setFaceStatus('Yêu cầu mới: ' + rentalChallengeInstruction + '. Hệ thống sẽ tự kiểm tra hành động lại.', false);
                        startRentalActionCheckLoop();
                    })
                    .catch(function () {
                        setFaceStatus('Không thể tạo yêu cầu xác thực mới. Vui lòng đóng và thử lại.', true);
                    });
            }

            function runRentalFaceVerify(isAuto) {
                var productId = borrowButton.getAttribute('data-product-id');
                if (!rentalChallengeToken) {
                    setFaceStatus('Vui lòng mở lại camera để nhận yêu cầu xác thực mới.', true);
                    return;
                }

                if (!rentalActionMatched) {
                    startRentalActionCheckLoop();
                    return;
                }

                clearRentalActionCheckTimer();
                captureFaceButton.disabled = true;
                setFaceStatus(isAuto ? 'Đang tự xác nhận khuôn mặt...' : 'Đang xác nhận khuôn mặt...', false);

                FaceCapture.captureBlob(faceVideo)
                    .then(function (blob) {
                        return FaceCapture.uploadFace('/FaceAuth/VerifyRentalFace', blob, {
                            productId: productId,
                            challengeToken: rentalChallengeToken
                        });
                    })
                    .then(function (faceResult) {
                        if (!faceResult || !faceResult.success) {
                            setFaceStatus((faceResult && (faceResult.message || faceResult.error)) || 'Xác nhận khuôn mặt thất bại. Vui lòng thử lại.', true);
                            captureFaceButton.disabled = false;
                            return null;
                        }

                        setFaceStatus('Xác nhận khuôn mặt thành công. Đang gửi yêu cầu mượn...', false);
                        closeFacePanel(false);
                        borrowButton.disabled = true;
                        borrowButton.textContent = 'Đang gửi yêu cầu';
                        setStatus('Đã xác thực khuôn mặt. Đang gửi yêu cầu mượn sách...', false);
                        return postForm('/Rental/RequestRental', {
                            productId: productId,
                            requestDate: requestDate.value,
                            borrowDays: borrowDays.value,
                            faceToken: faceResult.faceToken,
                            details: 'ProductID=' + productId,
                            identityNumber: identityNumber.value,
                            identityFullName: identityFullName.value
                        });
                    })
                    .then(function (rentalResult) {
                        if (!rentalResult) return;

                        if (rentalResult.success) {
                            updateRentalBadge(rentalResult.activeRentalCount);
                            markRentalRequested();
                        } else {
                            enableBorrow();
                            setStatus((rentalResult && rentalResult.error) || 'Không thể gửi yêu cầu mượn sách.', true);
                        }
                    })
                    .catch(function () {
                        setFaceStatus('Không thể chụp hoặc gửi ảnh khuôn mặt.', true);
                        enableBorrow();
                        setStatus('Không thể gửi yêu cầu mượn sách sau khi xác thực. Vui lòng thử lại.', true);
                    })
                    .then(function () {
                        captureFaceButton.disabled = false;
                    });
            }

            function postForm(url, fields) {
                var form = new FormData();
                Object.keys(fields).forEach(function (key) {
                    if (fields[key] !== undefined && fields[key] !== null) {
                        form.append(key, fields[key]);
                    }
                });
                return fetch(url, {
                    method: 'POST',
                    body: form,
                    credentials: 'same-origin'
                }).then(function (response) { return response.json(); });
            }

            function today() {
                var d = new Date();
                return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
            }

            function enableBorrow() {
                borrowButton.disabled = false;
                borrowButton.textContent = 'Mượn sách';
                setStatus('Bạn đang ở trong khu vực hỗ trợ mượn sách tại ' + activeStoreName + '.', false);
            }

            function disableBorrow(message) {
                borrowButton.disabled = true;
                setStatus(message || 'Chỉ hỗ trợ mượn tại cửa hàng.', true);
            }

            function markAlreadyBorrowing() {
                borrowButton.disabled = true;
                borrowButton.textContent = 'Đang mượn sách';
                setStatus('Bạn đang mượn hoặc đang chờ duyệt cuốn sách này.', true);
            }

            function markRentalRequested() {
                borrowButton.disabled = true;
                borrowButton.textContent = 'Đang chờ duyệt';
                requestPanel.style.display = 'none';
                setStatus('Yêu cầu mượn sách đã được gửi. Vui lòng chờ admin xác nhận.', false);
            }

            if (!navigator.geolocation) {
                disableBorrow('Trình duyệt không hỗ trợ định vị.');
                return;
            }

            navigator.geolocation.getCurrentPosition(function (position) {
                postForm('/Geofence/CheckGeofence', {
                    lat: position.coords.latitude,
                    lon: position.coords.longitude
                }).then(function (result) {
                    if (result && result.inZone) {
                        activeStoreName = result.storeName || activeStoreName;
                        return postForm('/Rental/CheckActiveRental', {
                            productId: borrowButton.getAttribute('data-product-id')
                        }).then(function (rentalState) {
                            if (rentalState && rentalState.hasActiveRental) {
                                markAlreadyBorrowing();
                            } else {
                                enableBorrow();
                            }
                        });
                    } else {
                        if (result && result.storeName) activeStoreName = result.storeName;
                        disableBorrow((result && result.error) || ('Chỉ hỗ trợ mượn sách tại ' + activeStoreName + '.'));
                    }
                }).catch(function () {
                    disableBorrow('Không thể kiểm tra vị trí.');
                });
            }, function () {
                disableBorrow('Vui lòng cấp quyền vị trí để mượn sách.');
            }, {
                enableHighAccuracy: true,
                timeout: 10000,
                maximumAge: 60000
            });

            borrowButton.addEventListener('click', function () {
                checkRentalProfileBeforeBorrow().catch(function () {
                    setStatus('Không thể kiểm tra hồ sơ mượn sách.', true);
                });
            });

            closeRentalProfileBtn.addEventListener('click', closeRentalProfilePanel);

            rentalProfilePanel.addEventListener('click', function (event) {
                if (event.target === rentalProfilePanel) {
                    closeRentalProfilePanel();
                }
            });

            ocrRentalProfileBtn.addEventListener('click', function () {
                var hasFront = rentalProfileIdentityFrontFile.files && rentalProfileIdentityFrontFile.files.length;
                var hasBack = rentalProfileIdentityBackFile.files && rentalProfileIdentityBackFile.files.length;
                if (!hasFront && !hasBack) {
                    setRentalProfileStatus('Vui lòng chọn ảnh CMND/CCCD mặt trước hoặc mặt sau để OCR.', true);
                    return;
                }

                ocrRentalProfileBtn.disabled = true;
                setRentalProfileStatus('Đang đọc CMND/CCCD...', false);
                postForm('/FaceAuth/OcrCmnd', {
                    front_file: hasFront ? rentalProfileIdentityFrontFile.files[0] : null,
                    back_file: hasBack ? rentalProfileIdentityBackFile.files[0] : null
                }).then(function (result) {
                    if (!result || !result.success) {
                        setRentalProfileStatus(((result && result.message) || 'Không thể đọc CMND/CCCD.') + ' Bạn có thể nhập tay và bấm Lưu.', true);
                        return;
                    }

                    var fields = result.fields || {};
                    rentalProfileIdentityNumber.value = fields.identityNumber || rentalProfileIdentityNumber.value;
                    rentalProfileIdentityFullName.value = fields.fullName || rentalProfileIdentityFullName.value;
                    setRentalProfileStatus(result.faceMatched ? 'Đã đọc CMND/CCCD và khuôn mặt khớp tài khoản.' : 'Đã đọc CMND/CCCD. Vui lòng kiểm tra dữ liệu.', false);
                }).catch(function () {
                    setRentalProfileStatus('Không thể đọc CMND/CCCD.', true);
                }).then(function () {
                    ocrRentalProfileBtn.disabled = false;
                });
            });

            saveRentalProfileBtn.addEventListener('click', function () {
                if (!rentalProfileEmail.value.trim() || !rentalProfileIdentityNumber.value.trim() || !rentalProfileIdentityFullName.value.trim()) {
                    setRentalProfileStatus('Vui lòng nhập Gmail nhận thông báo, số CMND/CCCD và họ tên.', true);
                    return;
                }

                saveRentalProfileBtn.disabled = true;
                setRentalProfileStatus('Đang lưu thông tin...', false);
                postForm('/Rental/UpdateRentalProfile', {
                    notificationEmail: rentalProfileEmail.value,
                    identityNumber: rentalProfileIdentityNumber.value,
                    identityFullName: rentalProfileIdentityFullName.value,
                    identityCardFrontFile: rentalProfileIdentityFrontFile.files && rentalProfileIdentityFrontFile.files.length ? rentalProfileIdentityFrontFile.files[0] : null,
                    identityCardBackFile: rentalProfileIdentityBackFile.files && rentalProfileIdentityBackFile.files.length ? rentalProfileIdentityBackFile.files[0] : null
                }).then(function (result) {
                    if (!result || !result.success) {
                        setRentalProfileStatus((result && result.error) || 'Không thể lưu thông tin mượn sách.', true);
                        return;
                    }

                    if (identityNumber) identityNumber.value = rentalProfileIdentityNumber.value;
                    if (identityFullName) identityFullName.value = rentalProfileIdentityFullName.value;
                    closeRentalProfilePanel();
                    openRentalRequestPanel();
                }).catch(function () {
                    setRentalProfileStatus('Không thể lưu thông tin mượn sách.', true);
                }).then(function () {
                    saveRentalProfileBtn.disabled = false;
                });
            });

            cancelInfoButton.addEventListener('click', function () {
                requestPanel.style.display = 'none';
                setStatus('Đã hủy thao tác mượn sách.', true);
            });

            confirmInfoButton.addEventListener('click', function () {
                var productId = borrowButton.getAttribute('data-product-id');
                var days = parseInt(borrowDays.value, 10);
                if (!days || days < 1 || days > 30) {
                    setStatus('Số ngày mượn phải từ 1 đến 30.', true);
                    return;
                }
                confirmInfoButton.disabled = true;
                setStatus('Đang kiểm tra tồn kho...', false);
                postForm('/Rental/CheckStock', {
                    productId: productId,
                    quantity: 1
                }).then(function (stockResult) {
                    confirmInfoButton.disabled = false;
                    if (!stockResult || !stockResult.available) {
                        setStatus('Sách hiện đã hết hàng, không thể gửi yêu cầu mượn.', true);
                        return;
                    }

                    requestPanel.style.display = 'none';
                    openFacePanel();
                    setFaceStatus('Đang tạo yêu cầu xác thực...', false);
                    if (window.FaceCapture) {
                        loadRentalChallenge()
                            .then(function () {
                                return FaceCapture.startCamera(faceVideo, faceStatus);
                            })
                            .then(function (stream) {
                                faceStream = stream;
                                setFaceStatus('Yêu cầu: ' + rentalChallengeInstruction + '. Hệ thống sẽ tự nhận diện khi bạn làm đúng hành động.', false);
                                startRentalActionCheckLoop();
                            }).catch(function () {
                                setFaceStatus('Không thể mở camera hoặc tạo yêu cầu xác thực.', true);
                            });
                    }
                }).catch(function () {
                    confirmInfoButton.disabled = false;
                    setStatus('Không thể kiểm tra tồn kho.', true);
                });
            });

            cancelFaceButton.addEventListener('click', function () {
                closeFacePanel(true);
            });

            closeFaceButton.addEventListener('click', function () {
                closeFacePanel(true);
            });

            facePanel.addEventListener('click', function (event) {
                if (event.target === facePanel) {
                    closeFacePanel(true);
                }
            });

            captureFaceButton.addEventListener('click', function () {
                runRentalFaceVerify(false);
            });

            window.addEventListener('beforeunload', function () {
                if (window.FaceCapture) FaceCapture.stopCamera(faceStream);
            });
        })();
    </script>
    }else
    {
        Url.Action("NotFound");
    }
