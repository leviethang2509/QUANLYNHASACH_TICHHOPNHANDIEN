@model Mood.EF2.Sanpham
@{
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
    var category = (Mood.EF2.Category)ViewBag.sanPhamCategory;
    var splienquan = (List<Mood.EF2.Sanpham>)ViewBag.sanPhamLienquan;
    var productReviews = (List<Mood.EF2.ProductReview>)ViewBag.ProductReviews ?? new List<Mood.EF2.ProductReview>();
    var reviewCount = (int)(ViewBag.ProductReviewCount ?? 0);
    var averageRating = (double)(ViewBag.ProductAverageRating ?? 0D);
    var youtubeEmbedUrl = (ViewBag.YoutubeEmbedUrl as string) ?? "";
}
@if (Model != null)
{
    <!-- ====== MAIN CONTENT ====== -->
    <div class="page-header border-bottom">
        <div class="container">
            <div class="d-md-flex justify-content-between align-items-center py-4">
                <h1 class="page-title font-size-3 font-weight-medium mb-md-0 text-lh-lg">THÔNG TIN SẢN PHẨM</h1>
                <nav class="woocommerce-breadcrumb font-size-2">
                    <a href="/trang-chu" class="h-primary">Trang Chủ</a>
                    <span class="breadcrumb-separator mx-1"><i class="fas fa-angle-right"></i></span>
                    <a href="/san-pham" class="h-primary">Sản Phẩm</a>
                    <span class="breadcrumb-separator mx-1"><i class="fas fa-angle-right"></i></span>
                    @if (category != null)
                    {
                        <a href="/danh-muc/@category.MetaTitle-@category.IDCategory" class="h-primary">@category.TenTheloai</a>
                        <span class="breadcrumb-separator mx-1"><i class="fas fa-angle-right"></i></span>
                    }
                    @Model.Name
                </nav>
            </div>
        </div>
    </div>
    <div id="primary" class="content-area">
        <main id="main" class="site-main ">
            <div class="product">
                <div class="container mb-6">
                    <div class="row">
                        <div class="col-md-4 col-lg-3 woocommerce-product-gallery woocommerce-product-gallery--with-images images">
                            <figure class="woocommerce-product-gallery__wrapper pt-8 mb-0">
                                <div class="js-slick-carousel u-slick"
                                     data-autoplay="true"
                                     data-autoplay-speed="5000"
                                     data-pagi-classes="text-center u-slick__pagination my-4">
                                    <div class="js-slide">
                                        <img src="@Model.Images" width="300" height="452" alt="Image Description" class="mx-auto img-fluid">
                                    </div>
                                    <div class="js-slide">
                                        <img src="@Model.Images" width="300" height="452" alt="Image Description" class="mx-auto img-fluid">
                                    </div>
                                    <div class="js-slide">
                                        <img src="@Model.Images" width="300" height="452" alt="Image Description" class="mx-auto img-fluid">
                                    </div>
                                </div>
                            </figure>
                        </div>
                        <div class="col-md-8 col-lg-5 pl-0 summary entry-summary">
                            <div class="space-top-2 pl-4 pl-wd-6 px-wd-7 pb-5">
                                <h1 class="product_title entry-title font-size-7 mb-3 text-main">@Model.Name</h1>
                                <div class="font-size-2 mb-4">
                                    <span class="text-yellow-darker">
                                        <span class="fas fa-star"></span>
                                        <span class="fas fa-star"></span>
                                        <span class="fas fa-star"></span>
                                        <span class="fas fa-star"></span>
                                        <span class="fas fa-star"></span>
                                    </span>
                                    @if (Model.Soluong != 0)
                                    {
                                        <span class="ml-3 text-muted">(Còn @Model.Soluong sản phẩm)</span>
                                    }
                                    else
                                    {
                                        <span class="ml-3 text-danger">(Tạm hết hàng)</span>
                                    }
                                    <span class="ml-3 font-weight-medium text-main">Bởi (Tác Giả)</span>
                                    <span class="ml-2 text-muted">@Model.TacGia</span>
                                </div>
                                <div class="woocommerce-product-details__short-description font-size-2 mb-5 text-muted">
                                    <p class="mb-0">@Model.Mota</p>

                                </div>

                                <ul class="list-unstyled my-0 list-features d-xl-flex align-items-center">
                                    <li class="list-feature mb-6 mb-xl-0 mr-xl-4 mr-wd-6">
                                        <div class="media">
                                            <div class="feature__icon font-size-46 text-primary text-lh-xs">
                                                <i class="glyph-icon flaticon-delivery"></i>
                                            </div>
                                            <div class="media-body ml-4">
                                                <h6 class="feature__title">Miễn phí</h6>
                                                <p class="feature__subtitle m-0"> Giao cho đơn trên 200k</p>
                                            </div>
                                        </div>
                                    </li>
                                    <li class="list-feature mb-6 mb-xl-0">
                                        <div class="media">
                                            <div class="feature__icon font-size-46 text-primary text-lh-xs">
                                                <i class="glyph-icon flaticon-credit"></i>
                                            </div>
                                            <div class="media-body ml-4">
                                                <h6 class="feature__title">Thanh Toán</h6>
                                                <p class="feature__subtitle m-0">100% Thanh Toán An Toàn</p>
                                            </div>
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="border border-color rounded-md bg-card mt-md-8 shadow-sm">
                                <div class="bg-app border-bottom border-color py-4 px-5">
                                    <p class="price font-size-22 font-weight-medium mb-0 text-main">
                                        @{
                                            var price_saleList = 0;
                                            var price_dealList = 0;
                                            var price_tietkiem = 0;
                                            if (Model.PriceSale != null)
                                            {
                                                price_saleList = (int)Model.PriceSale;
                                                price_dealList = (Model.GiaTien - Model.GiaTien / 100 * (price_saleList));
                                                price_tietkiem = (int)(Model.GiaTien - price_dealList);
                                            }
                                        }
                                        @if (price_saleList > 0)
                                        {
                                            <span class="woocommerce-Price-amount amount text-primary">
                                                @price_dealList.ToString("N0")đ <span class="font-size-1 font-weight-regular text-danger ml-2"><span class="woocommerce-Price-amount amount">Tiết kiệm @price_tietkiem.ToString("N0")đ</span></span>
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="woocommerce-Price-amount amount text-primary">
                                                @Model.GiaTien.ToString("N0") đ
                                            </span>
                                        }
                                    </p>
                                </div>
                                <div class="py-4 px-5 bg-card">



                                    <form class="cart mb-4" method="post" enctype="multipart/form-data">
                                        <label class="form-label font-size-2 font-weight-medium">Số Lượng</label>
                                        <div class="quantity mb-4 d-flex align-items-center">
                                            <!-- Quantity -->
                                            <div class="border px-3 w-100">
                                                <div class="js-quantity">
                                                    <div class="d-flex align-items-center">

                                                        <label class="screen-reader-text sr-only">Số Lượng</label>
                                                        <a class="js-minus text-dark" href="javascript:;">
                                                            <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="10px" height="1px">
                                                                <path fill-rule="evenodd" fill="rgb(22, 22, 25)" d="M-0.000,-0.000 L10.000,-0.000 L10.000,1.000 L-0.000,1.000 L-0.000,-0.000 Z" />
                                                            </svg>
                                                        </a>
                                                        <input type="number" class="input-text qty text js-result form-control text-center border-0" step="1" min="1" max="100" name="quantity" value="1" title="Qty">
                                                        <a class="js-plus text-dark" href="javascript:;">
                                                            <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="10px" height="10px">
                                                                <path fill-rule="evenodd" fill="rgb(22, 22, 25)" d="M10.000,5.000 L6.000,5.000 L6.000,10.000 L5.000,10.000 L5.000,5.000 L-0.000,5.000 L-0.000,4.000 L5.000,4.000 L5.000,-0.000 L6.000,-0.000 L6.000,4.000 L10.000,4.000 L10.000,5.000 Z" />
                                                            </svg>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- End Quantity -->
                                        </div>

                                        <a href="javascript:void(0)" onclick="addcartHome(@Model.IDContent)" name="add-to-cart" value="7145" class="btn btn-block btn-primary border-0 rounded-md p-3 single_add_to_cart_button button alt shadow-sm hover-up text-white">Thêm vào giỏ</a>
                                        <button id="borrowBookBtn" type="button" class="btn btn-block btn-secondary border-0 rounded-md p-3 mt-3 shadow-sm hover-up text-white" disabled data-product-id="@Model.IDContent">Mượn sách</button>
                                        <div id="borrowBookStatus" class="font-size-2 mt-2 text-muted"><i class="fas fa-spinner fa-spin mr-1"></i> Đang kiểm tra vị trí...</div>
                                    </form>

                                    <div id="rentalRequestPanel" class="card border border-color p-4 mt-4 shadow-md bg-app" style="display:none;">
                                        <h3 class="font-size-3 mb-3 font-weight-bold text-primary"><i class="fas fa-info-circle mr-1"></i> Thông tin mượn sách</h3>
                                        <div class="form-group">
                                            <label for="rentalRequestDate" class="font-weight-medium text-main">Ngày yêu cầu</label>
                                            <input id="rentalRequestDate" type="date" class="form-control rounded-md bg-card text-main border-color" readonly />
                                        </div>
                                        <div class="form-group">
                                            <label for="rentalBorrowDays" class="font-weight-medium text-main">Số ngày mượn</label>
                                            <input id="rentalBorrowDays" type="number" min="1" max="30" value="7" class="form-control rounded-md bg-card text-main border-color" />
                                        </div>
                                        <div class="form-group">
                                            <label for="rentalIdentityNumber" class="font-weight-medium text-main">Số CMND/CCCD</label>
                                            <input id="rentalIdentityNumber" type="text" class="form-control rounded-md bg-app text-muted border-color" readonly />
                                        </div>
                                        <div class="form-group">
                                            <label for="rentalIdentityFullName" class="font-weight-medium text-main">Họ tên trên CMND/CCCD</label>
                                            <input id="rentalIdentityFullName" type="text" class="form-control rounded-md bg-app text-muted border-color" readonly />
                                        </div>
                                        <div class="d-flex mt-3">
                                            <button id="confirmRentalInfoBtn" type="button" class="btn btn-primary rounded-md px-4 mr-2">Xác nhận</button>
                                            <button id="cancelRentalInfoBtn" type="button" class="btn btn-outline-secondary rounded-md px-4">Hủy</button>
                                        </div>
                                    </div>

                                    <div id="rentalProfilePanel" class="face-auth-modal" hidden>
                                        <div class="face-auth-dialog card border-color shadow-lg p-0" role="dialog" aria-modal="true" aria-labelledby="rentalProfileTitle">
                                            <div class="face-auth-header bg-primary text-white p-3 d-flex justify-content-between align-items-center">
                                                <h3 id="rentalProfileTitle" class="face-auth-title text-white mb-0 font-size-3"><i class="fas fa-id-card mr-1"></i> Cập nhật thông tin mượn sách</h3>
                                                <button id="closeRentalProfileBtn" type="button" class="face-auth-close text-white border-0 bg-transparent font-size-5" aria-label="Đóng">&times;</button>
                                            </div>
                                            <div class="face-auth-body p-4 bg-card">
                                                <div class="form-group">
                                                    <label for="rentalProfileEmail" class="font-weight-medium text-main">Gmail nhận thông báo</label>
                                                    <input id="rentalProfileEmail" type="email" class="form-control rounded-md bg-card text-main border-color" />
                                                </div>
                                                <div class="form-group">
                                                    <label for="rentalProfileIdentityNumber" class="font-weight-medium text-main">Số CMND/CCCD</label>
                                                    <input id="rentalProfileIdentityNumber" type="text" class="form-control rounded-md bg-card text-main border-color" />
                                                </div>
                                                <div class="form-group">
                                                    <label for="rentalProfileIdentityFullName" class="font-weight-medium text-main">Họ tên trên CMND/CCCD</label>
                                                    <input id="rentalProfileIdentityFullName" type="text" class="form-control rounded-md bg-card text-main border-color" />
                                                </div>
                                                <div class="form-group">
                                                    <label for="rentalProfileIdentityFrontFile" class="font-weight-medium text-main">Ảnh CMND/CCCD mặt trước</label>
                                                    <input id="rentalProfileIdentityFrontFile" type="file" accept=".jpg,.jpeg,.png,image/jpeg,image/png" class="form-control rounded-md bg-card text-main border-color" />
                                                </div>
                                                <div class="form-group">
                                                    <label for="rentalProfileIdentityBackFile" class="font-weight-medium text-main">Ảnh CMND/CCCD mặt sau</label>
                                                    <input id="rentalProfileIdentityBackFile" type="file" accept=".jpg,.jpeg,.png,image/jpeg,image/png" class="form-control rounded-md bg-card text-main border-color" />
                                                </div>
                                                <div class="font-size-2 mb-3 text-muted"><i class="fas fa-info-circle mr-1"></i> Ảnh CMND/CCCD và OCR không bắt buộc. Nếu máy chủ chưa có Tesseract, bạn vẫn có thể nhập tay số giấy tờ và họ tên rồi lưu.</div>
                                                <div id="rentalProfileStatus" class="font-size-2 mb-3 text-muted"></div>
                                                <div class="face-auth-actions d-flex justify-content-end mt-3">
                                                    <button id="ocrRentalProfileBtn" type="button" class="btn btn-outline-secondary rounded-md mr-2"><i class="fas fa-eye mr-1"></i> Đọc CMND/CCCD</button>
                                                    <button id="saveRentalProfileBtn" type="button" class="btn btn-primary rounded-md"><i class="fas fa-arrow-right mr-1"></i> Lưu và tiếp tục</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div id="rentalFacePanel" class="face-auth-modal" hidden>
                                        <div class="face-auth-dialog card border-color shadow-lg p-0" role="dialog" aria-modal="true" aria-labelledby="rentalFaceTitle">
                                            <div class="face-auth-header bg-primary text-white p-3 d-flex justify-content-between align-items-center">
                                                <h3 id="rentalFaceTitle" class="face-auth-title text-white mb-0 font-size-3"><i class="fas fa-user-shield mr-1"></i> Xác nhận khuôn mặt</h3>
                                                <button id="closeRentalFaceBtn" type="button" class="face-auth-close text-white border-0 bg-transparent font-size-5" aria-label="Đóng">&times;</button>
                                            </div>
                                            <div class="face-auth-body p-4 text-center bg-card">
                                                <div class="face-scanner-box mx-auto mb-3" style="max-width: 320px;">
                                                    <div class="face-scanner-line"></div>
                                                    <video id="rentalFaceVideo" class="face-auth-video w-100 rounded-lg" style="transform: scaleX(-1);" autoplay muted playsinline></video>
                                                </div>
                                                <div id="rentalFaceStatus" class="font-size-2 mt-2 text-muted"></div>
                                                <div class="face-auth-actions d-flex justify-content-center mt-3">
                                                    <button id="captureRentalFaceBtn" type="button" class="btn btn-primary rounded-md mr-2"><i class="fas fa-camera mr-1"></i> Nhận diện và xác nhận</button>
                                                    <button id="cancelRentalFaceBtn" type="button" class="btn btn-outline-secondary rounded-md">Đóng</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <ul class="list-unstyled nav d-block d-md-flex justify-content-center">
                                        <li class="mr-md-4 mb-4 mb-md-0">
                                            <button type="button" class="btn btn-link h-primary p-0 js-favorite-toggle" data-icon-only="true" data-product-id="@Model.IDContent" title="Thêm vào yêu thích" aria-label="Thêm vào yêu thích"><i class="flaticon-heart font-size-4"></i></button>
                                        </li>
                                        <li class="mr-md-4 mb-4 mb-md-0">
                                            @if (!string.IsNullOrWhiteSpace(Model.ReviewFilePath))
                                            {
                                                <button type="button" class="btn btn-link h-primary p-0" data-toggle="modal" data-target="#bookReviewFileModal"><i class="fas fa-file-alt mr-2"></i> Xem review sách</button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-link text-muted p-0" disabled><i class="fas fa-file-alt mr-2"></i> Hiện chưa được xem review</button>
                                            }
                                        </li>
                                        <li class="">
                                            <a href="#" class="h-primary"><i class="flaticon-share mr-2"></i> Chia Sẻ</a>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ReviewFilePath))
                {
                    <div class="modal fade" id="bookReviewFileModal" tabindex="-1" role="dialog" aria-labelledby="bookReviewFileTitle" aria-hidden="true">
                        <div class="modal-dialog modal-xl" role="document">
                            <div class="modal-content rounded-0">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="bookReviewFileTitle">Review sách: @Model.Name</h5>
                                    <button type="button" class="close" data-dismiss="modal" aria-label="Đóng">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                                <div class="modal-body p-0">
                                    <iframe src="@Url.Action("ReviewFilePreview", "Product", new { id = Model.IDContent })" title="Review sách" style="width:100%;height:75vh;border:0;"></iframe>
                                </div>
                                <div class="modal-footer">
                                    <a href="@Url.Action("ReviewFilePreview", "Product", new { id = Model.IDContent })" target="_blank" class="btn btn-outline-dark rounded-0">Mở trang xem</a>
                                    <a href="@Url.Action("ReviewFileDownload", "Product", new { id = Model.IDContent })" class="btn btn-dark rounded-0">Tải file</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Features Section -->
                <div class="woocommerce-tabs wc-tabs-wrapper mb-10">
                    <!-- Nav Classic -->
                    <ul class="tabs wc-tabs nav border-bottom justify-content-md-center flex-nowrap flex-md-wrap overflow-auto overflow-md-visble" id="pills-tab" role="tablist">
                        <li class="flex-shrink-0 flex-md-shrink-1 nav-item">
                            <a class="py-4 nav-link font-weight-medium active" id="pills-one-example1-tab" data-toggle="pill" href="#pills-one-example1" role="tab" aria-controls="pills-one-example1" aria-selected="true">
                                Mô Tả Ngắn
                            </a>
                        </li>
                        <li class="flex-shrink-0 flex-md-shrink-1 nav-item">
                            <a class="py-4 nav-link font-weight-medium" id="pills-two-example1-tab" data-toggle="pill" href="#pills-two-example1" role="tab" aria-controls="pills-two-example1" aria-selected="false">
                                Chi Tiết
                            </a>
                        </li>
                        <li class="flex-shrink-0 flex-md-shrink-1 nav-item">
                            <a class="py-4 nav-link font-weight-medium" id="pills-three-example1-tab" data-toggle="pill" href="#pills-three-example1" role="tab" aria-controls="pills-three-example1" aria-selected="false">
                                Videos
                            </a>
                        </li>
                        <li class="flex-shrink-0 flex-md-shrink-1 nav-item">
                            <a class="py-4 nav-link font-weight-medium" id="pills-four-example1-tab" data-toggle="pill" href="#pills-four-example1" role="tab" aria-controls="pills-four-example1" aria-selected="false">
                                Đánh Giá
                            </a>
                        </li>
                    </ul>
                    <!-- End Nav Classic -->
                    <!-- Tab Content -->
                    <div class="tab-content container" id="pills-tabContent">
                        <div class="woocommerce-Tabs-panel panel col-xl-8 offset-xl-2 entry-content wc-tab tab-pane fade pt-9 show active" id="pills-one-example1" role="tabpanel" aria-labelledby="pills-one-example1-tab">
                            <!-- Mockup Block -->
                            <p class="mb-0">@Model.ChiTiet</p>

                            <!-- End Mockup Block -->
                        </div>
                        <div class="woocommerce-Tabs-panel panel col-xl-8 offset-xl-2 entry-content wc-tab tab-pane fade pt-9" id="pills-two-example1" role="tabpanel" aria-labelledby="pills-two-example1-tab">
                            <!-- Mockup Block -->
                            <div class="table-responsive mb-4">
                                <table class="table table-hover table-borderless">
                                    <tbody>
                                        <tr>
                                            <th class="px-4 px-xl-5">Định Dạng: </th>
                                            <td class="">Bìa Cứng | 384 trang</td>
                                        </tr>
                                        <tr>
                                            <th class="px-4 px-xl-5">Thông số</th>
                                            <td>9126 x 194 x 28mm | 301g</td>
                                        </tr>
                                        <tr>
                                            <th class="px-4 px-xl-5">Ngày xuất bản: </th>
                                            <td>20 Dec 2020</td>
                                        </tr>
                                        <tr>
                                            <th class="px-4 px-xl-5">Số lượng:</th>
                                            <td>@Model.Soluong tác phẩm</td>
                                        </tr>

                                       
                                        <tr>
                                            <th class="px-4 px-xl-5">Ngôn Ngữ:</th>
                                            <td>Tiếng Việt</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <!-- End Mockup Block -->
                        </div>
                       
                        <div class="woocommerce-Tabs-panel panel col-xl-8 offset-xl-2 entry-content wc-tab tab-pane fade pt-9" id="pills-three-example1" role="tabpanel" aria-labelledby="pills-three-example1-tab">
                            @if (!string.IsNullOrWhiteSpace(youtubeEmbedUrl))
                            {
                                <div class="embed-responsive embed-responsive-16by9">
                                    <iframe class="embed-responsive-item" src="@youtubeEmbedUrl" allowfullscreen title="Video @Model.Name"></iframe>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">Sản phẩm này chưa có video.</p>
                            }
                        </div>

                        <div class="woocommerce-Tabs-panel panel col-xl-8 offset-xl-2 entry-content wc-tab tab-pane fade pt-9" id="pills-four-example1" role="tabpanel" aria-labelledby="pills-four-example1-tab">
                            <h4 class="font-size-3 text-main">Khách hàng đánh giá</h4>
                            <div class="row mb-8">
                                <div class="col-md-6 mb-6 mb-md-0">
                                    <div class="d-flex  align-items-center mb-4">
                                        <span class="font-size-15 font-weight-bold text-main">@averageRating.ToString("0.0")</span>
                                        <div class="ml-3 h6 mb-0 text-main">
                                            <span class="font-weight-normal text-muted">@reviewCount lượt</span>
                                            <div class="text-yellow-darker">
                                                @for (var i = 1; i <= 5; i++)
                                                {
                                                    <small class="@(i <= Math.Round(averageRating) ? "fas" : "far") fa-star"></small>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <form id="productReviewForm">
                                        <input type="hidden" name="productId" value="@Model.IDContent" />
                                        <div class="form-group">
                                            <label class="text-main">Số sao</label>
                                            <select name="rating" class="form-control rounded-md bg-card text-main border-color">
                                                <option value="5">5 sao</option>
                                                <option value="4">4 sao</option>
                                                <option value="3">3 sao</option>
                                                <option value="2">2 sao</option>
                                                <option value="1">1 sao</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label class="text-main">Bình luận</label>
                                            <textarea name="comment" rows="4" class="form-control rounded-md bg-card text-main border-color" maxlength="1000"></textarea>
                                        </div>
                                        <button type="submit" class="btn btn-primary text-white px-4">Gửi đánh giá</button>
