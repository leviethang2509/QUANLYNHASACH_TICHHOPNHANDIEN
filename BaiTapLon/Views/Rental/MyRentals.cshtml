@using System.Linq
@model IEnumerable<BaiTapLon.Controllers.RentalController.RentalTrackingItem>
@{
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
    var status = ViewBag.Status as string;
    var items = Model ?? Enumerable.Empty<BaiTapLon.Controllers.RentalController.RentalTrackingItem>();
    Func<string, bool, string> displayStatus = (itemStatus, isOverdue) =>
    {
        if (isOverdue && itemStatus != "Returned") return "Trả trễ";
        switch (itemStatus)
        {
            case "Pending": return "Chờ duyệt";
            case "Approved": return "Đã duyệt";
            case "Borrowed":
            case "Borrowing": return "Đang mượn";
            case "Returned": return "Đã trả";
            case "Rejected": return "Từ chối";
            case "Cancelled": return "Đã hủy";
            case "Overdue": return "Trả trễ";
            default: return string.IsNullOrWhiteSpace(itemStatus) ? "Không rõ" : itemStatus;
        }
    };
    Func<string, bool, string> statusClass = (itemStatus, isOverdue) =>
    {
        if (isOverdue && itemStatus != "Returned") return "badge badge-danger";
        switch (itemStatus)
        {
            case "Pending": return "badge badge-warning";
            case "Borrowed":
            case "Borrowing":
            case "Approved": return "badge badge-primary";
            case "Returned": return "badge badge-success";
            case "Rejected":
            case "Cancelled": return "badge badge-secondary";
            case "Overdue": return "badge badge-danger";
            default: return "badge badge-light";
        }
    };
}

<div class="page-header border-bottom">
    <div class="container">
        <div class="py-4">
            <h1 class="page-title font-size-3 font-weight-medium mb-0">Quản lý sách đang mượn</h1>
        </div>
    </div>
</div>

<main class="container py-6">
    @if (TempData["RentalMessage"] != null)
    {
        <div class="alert alert-success rounded-0">@TempData["RentalMessage"]</div>
    }
    @if (TempData["RentalError"] != null)
    {
        <div class="alert alert-danger rounded-0">@TempData["RentalError"]</div>
    }

    <div class="row mb-4">
        <div class="col-6 col-md-3 mb-3">
            <div class="border p-3 h-100">
                <div class="text-muted small">Chờ duyệt</div>
                <strong>@ViewBag.PendingCount</strong>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="border p-3 h-100">
                <div class="text-muted small">Đang mượn</div>
                <strong>@ViewBag.BorrowingCount</strong>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="border p-3 h-100">
                <div class="text-muted small">Trả trễ</div>
                <strong>@ViewBag.OverdueCount</strong>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="border p-3 h-100">
                <div class="text-muted small">Đã trả</div>
                <strong>@ViewBag.ReturnedCount</strong>
            </div>
        </div>
    </div>

    <form method="get" class="mb-4">
        <div class="row">
            <div class="col-md-4">
                <select name="status" class="form-control rounded-0">
                    <option value="">Tất cả trạng thái</option>
                    <option value="Pending" @(status == "Pending" ? "selected" : "")>Chờ duyệt</option>
                    <option value="Borrowing" @(status == "Borrowing" ? "selected" : "")>Đang mượn</option>
                    <option value="Overdue" @(status == "Overdue" ? "selected" : "")>Trả trễ</option>
                    <option value="Returned" @(status == "Returned" ? "selected" : "")>Đã trả</option>
                    <option value="Rejected" @(status == "Rejected" ? "selected" : "")>Từ chối</option>
                    <option value="Cancelled" @(status == "Cancelled" ? "selected" : "")>Đã hủy</option>
                </select>
            </div>
            <div class="col-md-4 mt-2 mt-md-0">
                <button class="btn btn-primary rounded-0" type="submit">Lọc</button>
                <a class="btn btn-outline-dark rounded-0 ml-2" href="@Url.Action("MyRentals")">Xóa lọc</a>
            </div>
        </div>
    </form>

    @if (!items.Any())
    {
        <div class="alert alert-info rounded-0">Bạn chưa có yêu cầu mượn sách nào.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover">
                <thead>
                    <tr>
                        <th>Sách</th>
                        <th>Ngày yêu cầu</th>
                        <th>Số ngày mượn</th>
                        <th>Ngày dự kiến trả</th>
                        <th>Ngày trả thực tế</th>
                        <th>Trạng thái</th>
                        <th>Ghi chú</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in items)
                {
                    var isOverdue = item.Status != "Returned"
                        && item.Status != "Rejected"
                        && item.Status != "Cancelled"
                        && item.ExpectedReturnDate.Date < DateTime.Today;
                    <tr class="@(isOverdue ? "table-warning" : "")">
                        <td>
                            <div class="d-flex align-items-center">
                                @if (!string.IsNullOrWhiteSpace(item.ProductImage))
                                {
                                    <img src="@item.ProductImage" alt="@item.ProductName" style="width:48px;height:70px;object-fit:cover;" class="mr-3" />
                                }
                                <div>
                                    <div class="font-weight-bold">@item.ProductName</div>
                                    <div class="text-muted small">Mã yêu cầu: @item.ID</div>
                                </div>
                            </div>
                        </td>
                        <td>@item.RequestDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.BorrowDays</td>
                        <td>@item.ExpectedReturnDate.ToString("dd/MM/yyyy")</td>
                        <td>@(item.ActualReturnDate.HasValue ? item.ActualReturnDate.Value.ToString("dd/MM/yyyy") : "-")</td>
                        <td><span class="@statusClass(item.Status, isOverdue)">@displayStatus(item.Status, isOverdue)</span></td>
                        <td>@(string.IsNullOrWhiteSpace(item.RejectReason) ? "-" : item.RejectReason)</td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                using (Html.BeginForm("CancelRental", "Rental", FormMethod.Post, new { style = "display:inline" }))
                                {
                                    @Html.Hidden("id", item.ID)
                                    <button class="btn btn-outline-danger btn-sm rounded-0" type="submit">Hủy yêu cầu</button>
                                }
                            }
                            else
                            {
                                <span class="text-muted">Theo dõi</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</main>
