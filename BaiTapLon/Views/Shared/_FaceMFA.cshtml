@{
    var userId = User != null && User.Identity != null ? User.Identity.Name : "";
}

<div id="face-mfa">
    <h4>Xác thực khuôn mặt</h4>
    <video id="mfaVideo" width="320" height="240" autoplay muted playsinline></video>
    <div class="mt-2">
        <button id="mfaCaptureBtn" type="button" class="btn btn-primary">Xác thực</button>
    </div>
    <div id="mfaStatus" class="mt-2"></div>
</div>

<script src="/Scripts/FaceCapture.js"></script>
<script>
    FaceCapture.init({
        videoId: 'mfaVideo',
        buttonId: 'mfaCaptureBtn',
        statusId: 'mfaStatus',
        uploadUrl: '/FaceAuth/AuthenticateFace',
        fields: { userId: '@userId' },
        onResult: function (result) {
            var status = document.getElementById('mfaStatus');
            if (result && result.success) {
                status.className = 'mt-2 text-success';
                status.textContent = 'Xác thực thành công.';
                window.location.href = '/';
            } else {
                status.className = 'mt-2 text-danger';
                status.textContent = (result && result.error) || 'Xác thực thất bại.';
            }
        }
    });
</script>
