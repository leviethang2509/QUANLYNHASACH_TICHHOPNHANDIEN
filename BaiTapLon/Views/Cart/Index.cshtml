
@model List<BaiTapLon.Models.CartItem>
@using BaiTapLon.Common;
@{
    ViewBag.Title = "Giỏ hàng";
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
    var total = ViewBag.totalProduct;
    var session = (UserLogin)Session[Constant.USER_SESSION];
}
@section jsFooter{
    <script src="~/Content/Home/js/Controller/cartController1.js"></script>
    <script>

        $('#btnPaymentTrucTiep').off('click').on('click', function () {
            window.location.href = "/thanh-toan-truc-tuyen"
        });
    </script>
}

<div class="right-sidebar woocommerce-cart">
    <!-- ====== MAIN CONTENT ====== -->
    <div class="page-header border-bottom bg-card shadow-sm py-3">
        <div class="container">
            <div class="d-md-flex justify-content-between align-items-center">
                <h1 class="page-title font-size-4 font-weight-medium m-0 text-lh-lg">GIỎ HÀNG</h1>
                <nav class="woocommerce-breadcrumb font-size-2">
                    <a href="/Home/TrangChu" class="text-primary hover-up">Trang Chủ</a>
                    <span class="breadcrumb-separator mx-1 text-muted"><i class="fas fa-angle-right"></i></span>
                    <a href="/gio-hang/" class="text-primary hover-up">Giỏ Hàng</a>
                    <span class="breadcrumb-separator mx-1 text-muted"><i class="fas fa-angle-right"></i></span>
                    <span class="text-muted">Chi tiết giỏ hàng</span>
                </nav>
            </div>
        </div>
    </div>

    <div class="site-content overflow-hidden" id="content">
        
            <div class="container">
                <header class="entry-header space-top-2 space-bottom-1 mb-2">
                    <h1 class="entry-title font-size-6 font-weight-medium">Giỏ hàng của bạn: <span class="text-primary">@Model.Count()</span> sản phẩm</h1>
                </header>
@if (Model.Count > 0)
{
                <div class="row pb-8">
                    <div id="primary" class="col-lg-8 content-area">
                        <main id="main" class="site-main">
                            <div class="page type-page status-publish hentry card shadow-sm p-4 mb-4 bg-card border-color">
                                <!-- .entry-header -->
                                <div class="entry-content">
                                    <div class="woocommerce">
                                        <form class="woocommerce-cart-form table-responsive" action="#" method="post">
                                            <table class="table shop_table shop_table_responsive cart woocommerce-cart-form__contents text-main">
                                                <thead>
                                                    <tr class="border-bottom border-color">
                                                        <th class="product-name border-0 py-3 text-muted">Tên Sản Phẩm</th>
                                                        <th class="product-price border-0 py-3 text-muted">Giá Tiền</th>
                                                        <th class="product-quantity border-0 py-3 text-muted">Số Lượng</th>
                                                        <th class="product-subtotal border-0 py-3 text-muted">Thành Tiền</th>
                                                        <th class="product-remove border-0 py-3">&nbsp;</th>
                                                    </tr>
                                                </thead>

                                                <tbody>
                                                    @{ float sum = 0; }
                                                    @foreach (var item in Model)
                                                    {
                                                        var price_sale = 0;
                                                        if (item.Product.PriceSale != null)
                                                        {
                                                            price_sale = (int)item.Product.PriceSale;
                                                        }
                                                        var price_deal = (item.Product.GiaTien - item.Product.GiaTien / 100 * (price_sale));
                                                        sum += price_deal * item.Quantity;
                                                        var totalItem = price_deal * item.Quantity;
                                                        var url = "/chi-tiet/" + item.Product.MetaTitle + "-" + item.Product.IDContent;
                                                    <tr class="woocommerce-cart-form__cart-item cart_item border-bottom border-color align-middle">
                                                        <td class="product-name py-4" data-title="Product">
                                                            <div class="d-flex align-items-center">
                                                                <a href="@url" class="hover-up d-block rounded overflow-hidden shadow-sm" style="border: 1px solid var(--border-color);">
                                                                    <img src="@item.Product.Images" width="70" height="100" class="attachment-shop_thumbnail size-shop_thumbnail wp-post-image" alt="">
                                                                </a>
                                                                <div class="ml-3 m-w-200-lg-down">
                                                                    <a href="@url" class="font-weight-medium text-main hover-up d-block font-size-3">@item.Product.Name</a>
                                                                    <span class="text-muted font-size-2 d-block">@item.Product.TacGia</span>
                                                                </div>
                                                            </div>
                                                        </td>

                                                        <td class="product-price py-4 font-weight-medium" data-title="Price">
                                                            <span class="woocommerce-Price-amount amount">@price_deal.ToString("N0")đ</span>
                                                        </td>

                                                        <td class="product-quantity py-4" data-title="Quantity">
                                                            <div class="quantity d-flex align-items-center">
                                                                <!-- Quantity -->
                                                                <div class="border px-2 py-1 rounded-md bg-card border-color" style="width: 130px;">
                                                                    <div class="js-quantity">
                                                                        <div class="d-flex align-items-center justify-content-between">
                                                                            <label class="screen-reader-text sr-only">Quantity</label>
                                                                            <a class="js-minus text-main hover-up p-1" href="javascript:;">
                                                                                <i class="fas fa-minus font-size-1"></i>
                                                                            </a>
                                                                            <input type="number" class="input-text qty text js-result form-control text-center border-0 txtQuantity bg-transparent p-0 text-main font-weight-bold" style="box-shadow: none !important;" step="1" min="1" max="100" data-id="@item.Product.IDContent" name="quantity" value="@item.Quantity" title="Qty">
                                                                            <a class="js-plus text-main hover-up p-1" href="javascript:;">
                                                                                <i class="fas fa-plus font-size-1"></i>
                                                                            </a>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <!-- End Quantity -->
                                                            </div>
                                                        </td>

                                                        <td class="product-subtotal py-4 font-weight-bold text-primary" data-title="Total">
                                                            <span class="woocommerce-Price-amount amount">@totalItem.ToString("N0")đ</span>
                                                        </td>
                                                        <td class="product-remove py-4 text-center">
                                                            <a href="javascript:void(0)" class="remove_Item btn btn-sm btn-outline-danger rounded-circle p-2 hover-up" data-id="@item.Product.IDContent" aria-label="Remove this item" style="width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center;">
                                                                <i class="fas fa-times"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                    }


                                                    <tr>
                                                        <td colspan="5" class="actions pt-4 border-0">
                                                            <div class="d-flex flex-wrap align-items-center justify-content-end" style="gap: 10px;">
                                                                <input class="btn btn-primary rounded-md px-4 py-2 shadow-sm font-weight-medium btnTiepTuc" name="update_cart" value="Mua Hàng" style="cursor:pointer;">
                                                                <input class="btn btn-outline-primary rounded-md px-4 py-2 font-weight-medium btnUpdate" name="update_cart" value="Cập Nhật" style="cursor:pointer;">
                                                                <input class="btn btn-outline-danger rounded-md px-4 py-2 font-weight-medium btnDeleteAll" name="update_cart" value="Xóa tất cả" style="cursor:pointer;">
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </form>
                                    </div>
                                </div>
                                <!-- .entry-content -->
                            </div>
                        </main>
                    </div>
                    <div id="secondary" class="col-lg-4 sidebar cart-collaterals order-1" role="complementary">
                        <div id="cartAccordion" class="card shadow-sm mb-5 bg-card border-color">
                            <div class="p-4 border-bottom border-color">
                                <div id="cartHeadingOne" class="cart-head">
                                    <a class="d-flex align-items-center justify-content-between text-main hover-up" href="#"
                                       data-toggle="collapse"
                                       data-target="#cartCollapseOne"
                                       aria-expanded="true"
                                       aria-controls="cartCollapseOne">

                                        <h3 class="cart-title mb-0 font-weight-medium font-size-3 text-main">Chi Tiết Đơn Hàng</h3>
                                        <i class="fas fa-chevron-down font-size-2 text-muted"></i>
                                    </a>
                                </div>

                                <div id="cartCollapseOne" class="mt-4 cart-content collapse show"
                                     aria-labelledby="cartHeadingOne"
                                     data-parent="#cartAccordion">
                                    <table class="shop_table shop_table_responsive w-100 text-main">
                                        <tbody>
                                            <tr class="cart-subtotal d-flex justify-content-between py-2 border-bottom border-color">
                                                <th class="font-weight-normal border-0 text-muted">Tổng Tiền</th>
                                                <td data-title="Subtotal" class="font-weight-medium border-0"><span class="woocommerce-Price-amount amount">@sum.ToString("N0")đ</span></td>
                                            </tr>

                                            <tr class="order-shipping d-flex justify-content-between py-2">
                                                <th class="font-weight-normal border-0 text-muted">Giao hàng</th>
                                                <td data-title="Shipping" class="font-weight-medium border-0">Chờ xử lý</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="p-4 border-bottom border-color">
                                <div id="cartHeadingTwo" class="cart-head">
                                    <a class="d-flex align-items-center justify-content-between text-main hover-up" href="#"
                                       data-toggle="collapse"
                                       data-target="#cartCollapseTwo"
                                       aria-expanded="true"
                                       aria-controls="cartCollapseTwo">

                                        <h3 class="cart-title mb-0 font-weight-medium font-size-3 text-main">Vận Chuyển</h3>
                                        <i class="fas fa-chevron-down font-size-2 text-muted"></i>
                                    </a>
                                </div>

                                <div id="cartCollapseTwo" class="mt-4 cart-content collapse show"
                                     aria-labelledby="cartHeadingTwo"
                                     data-parent="#cartAccordion">
                                    <!-- Checkboxes -->
                                    <ul id="shipping_method" class="list-unstyled text-main">
                                        <li class="mb-2">
                                            <input type="radio" name="shipping_method[0]" data-index="0" id="shipping_method_0_flat_rate1" value="flat_rate:1" class="shipping_method">
                                            <label for="shipping_method_0_flat_rate1" class="ml-2 mb-0">Miễn Phí : Chậm</label>
                                        </li>

                                        <li class="mb-2">
                                            <input type="radio" name="shipping_method[0]" data-index="0" id="shipping_method_0_flat_rate2" value="flat_rate:2" class="shipping_method">
                                            <label for="shipping_method_0_flat_rate2" class="ml-2 mb-0">Trung Bình: <span class="woocommerce-Price-amount amount text-primary">30.000đ</span></label>
                                        </li>

                                        <li class="mb-2">
                                            <input type="radio" name="shipping_method[0]" data-index="0" id="shipping_method_0_flat_rate3" value="flat_rate:2" class="shipping_method" checked="checked">
                                            <label for="shipping_method_0_flat_rate3" class="ml-2 mb-0">Nhanh: <span class="woocommerce-Price-amount amount text-primary">45.000đ</span></label>
                                        </li>
                                    </ul>
                                    <!-- End Checkboxes -->
                                    <div class="mt-3">
                                        <span class="font-size-2 text-muted">Gửi đến.</span>
                                        <a href="#" class="font-weight-medium text-primary hover-up ml-2 font-size-2">Đổi địa chỉ</a>
                                    </div>
                                </div>
                            </div>

                            <div class="p-4 border-bottom border-color">
                                <div id="cartHeadingThree" class="cart-head">
                                    <a class="d-flex align-items-center justify-content-between text-main hover-up" href="#"
                                       data-toggle="collapse"
                                       data-target="#cartCollapseThree"
                                       aria-expanded="true"
                                       aria-controls="cartCollapseThree">

                                        <h3 class="cart-title mb-0 font-weight-medium font-size-3 text-main">Phiếu giảm giá</h3>
                                        <i class="fas fa-chevron-down font-size-2 text-muted"></i>
                                    </a>
                                </div>

                                <div id="cartCollapseThree" class="mt-4 cart-content collapse show"
                                     aria-labelledby="cartHeadingThree"
                                     data-parent="#cartAccordion">
                                    <div class="coupon">
                                        <label for="coupon_code" class="text-muted mb-2 font-size-2">Mã giảm giá:</label>
                                        <div class="input-group">
                                            <input type="text" name="coupon_code" class="form-control rounded-md px-3 border-color" id="coupon_code" value="" placeholder="Mã giảm giá" autocomplete="off">
                                            <div class="input-group-append">
                                                <input type="submit" class="btn btn-primary px-3 rounded-md" name="apply_coupon" value="Áp dụng" style="border-top-left-radius:0; border-bottom-left-radius:0;">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="p-4 bg-app border-top border-color">
                                <table class="shop_table shop_table_responsive w-100 text-main">
                                    <tbody>
                                        <tr class="order-total d-flex justify-content-between py-2 align-items-center">
                                            <th class="font-size-3 font-weight-bold text-main border-0 py-0">Tổng Thanh Toán</th>
                                            <td data-title="Total" class="border-0 py-0"><strong class="font-size-4 text-primary"><span class="woocommerce-Price-amount amount">@sum.ToString("N0")đ</span></strong> </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="wc-proceed-to-checkout">
                            @if (session != null)
                            {
                            <a href="/thanh-toan-truc-tuyen" class="checkout-button button alt wc-forward btn btn-primary btn-block rounded-md py-3 shadow-md font-weight-bold hover-up">Thanh Toán</a>
                            }
                            else
                            {
                            <a href="javascript:void(0)" onclick="thanhtoan()" class="checkout-button button alt wc-forward btn btn-primary btn-block rounded-md py-3 shadow-md font-weight-bold hover-up">Thanh Toán</a>
                            }
                        </div>
                    </div>
                </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="alert alert-danger rounded-md shadow-sm border-0 mb-8" role="alert">
               
                                                                    <span class="font-weight-medium">Hiện tại giỏ hàng chưa có sản phẩm.</span>
                                                               
                                                            </div>
                                                        }
            </div>
                                                        
    </div>

    <!-- ====== END MAIN CONTENT ====== -->
</div>